# ==============================================================================
# Dynamic Layout Expansion
# ==============================================================================
# Add/remove/scale agent panes dynamically in the current tmux window.
# Pane IDs are tracked in the @agent_panes window option (comma-separated).

# Internal: read alive agent pane IDs as an array
_dyn_read_panes() {
  local raw
  raw=$(tmux show-options -wqv @agent_panes 2>/dev/null)
  [[ -z $raw ]] && return
  local -a alive=()
  for p in ${raw//,/ }; do
    tmux display-message -p -t "$p" '#{pane_id}' &>/dev/null && alive+=("$p")
  done
  echo "${alive[*]}"
}

# Internal: write pane array back to window option
_dyn_write_panes() {
  local panes="$*"
  local csv="${panes// /,}"
  if [[ -z $csv ]]; then
    tmux set-option -wu @agent_panes 2>/dev/null
  else
    tmux set-option -w @agent_panes "$csv"
  fi
}

# Add an agent pane
# Usage: taa [command]
taa() {
  [[ -z $TMUX ]] && { echo "taa requires tmux."; return 1; }

  local cmd="${1:-claude}"
  local pane_id
  pane_id=$(tmux split-window -h -c "#{pane_current_path}" -P -F '#{pane_id}')
  tmux send-keys -t "$pane_id" "$cmd" Enter
  tmux select-layout tiled

  local existing
  existing=$(_dyn_read_panes)
  _dyn_write_panes $existing "$pane_id"

  printf '\033[0;33m+\033[0m Added agent pane %s running %s\n' "$pane_id" "$cmd"
}

# Remove an agent pane
# Usage: tra [pane_id]
tra() {
  [[ -z $TMUX ]] && { echo "tra requires tmux."; return 1; }

  local target="$1"
  local existing
  existing=$(_dyn_read_panes)
  [[ -z $existing ]] && { echo "No agent panes tracked."; return 1; }

  if [[ -z $target ]]; then
    # fzf picker
    target=$(
      for p in $existing; do
        local cmd
        cmd=$(tmux display-message -p -t "$p" '#{pane_current_command}' 2>/dev/null)
        printf '%s  %s\n' "$p" "$cmd"
      done | fzf --tmux 50%,40% \
        --header "Pick agent pane to remove" \
        --preview "tmux capture-pane -e -p -t {1}" \
        --delimiter ' ' \
        | awk '{print $1}'
    ) || return 0
    [[ -z $target ]] && return 0
  fi

  tmux kill-pane -t "$target" 2>/dev/null

  # Remove from tracking
  local -a remaining=()
  for p in $existing; do
    [[ $p != "$target" ]] && remaining+=("$p")
  done
  _dyn_write_panes "${remaining[@]}"

  tmux select-layout tiled 2>/dev/null
  printf '\033[0;31m-\033[0m Removed agent pane %s\n' "$target"
}

# Scale to N agent panes
# Usage: tscale <n> [command]
tscale() {
  [[ -z $TMUX ]] && { echo "tscale requires tmux."; return 1; }
  [[ -z $1 ]] && { echo "Usage: tscale <n> [command]"; return 1; }

  local target_count="$1"
  local cmd="${2:-claude}"
  local existing
  existing=$(_dyn_read_panes)
  local -a panes=($existing)
  local current=${#panes[@]}

  if (( target_count > current )); then
    local needed=$(( target_count - current ))
    for ((i=0; i<needed; i++)); do
      taa "$cmd"
    done
  elif (( target_count < current )); then
    # Remove newest first (from end of list)
    local to_remove=$(( current - target_count ))
    for ((i=0; i<to_remove; i++)); do
      local idx=$(( ${#panes[@]} - 1 - i ))
      tra "${panes[$idx]}"
    done
  fi

  printf '\033[0;32m=\033[0m Scaled to %d agent panes\n' "$target_count"
}

# List agent panes (shows dead panes too for diagnostics)
# Usage: tap
tap() {
  [[ -z $TMUX ]] && { echo "tap requires tmux."; return 1; }

  local raw
  raw=$(tmux show-options -wqv @agent_panes 2>/dev/null)
  [[ -z $raw ]] && { echo "No agent panes tracked."; return 0; }

  printf '\033[1;33m%-10s %-10s %s\033[0m\n' "PANE_ID" "STATUS" "COMMAND"
  for p in ${raw//,/ }; do
    local cmd status
    if tmux display-message -p -t "$p" '#{pane_id}' &>/dev/null; then
      status="\033[0;32malive\033[0m"
      cmd=$(tmux display-message -p -t "$p" '#{pane_current_command}' 2>/dev/null)
    else
      status="\033[0;31mdead\033[0m"
      cmd="-"
    fi
    printf "%-10s ${status}      %s\n" "$p" "$cmd"
  done
}
