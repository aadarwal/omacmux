# ------------------------------------------------------------------------------
# Pinning — add/remove items from persistent desktop view
# ------------------------------------------------------------------------------

# Check if an entry is pinned (type + name)
_atlas_is_pinned() {
  local type="$1" name="$2"
  # Active projects are implicitly pinned
  if [[ "$type" == "repo" ]]; then
    jq -e --arg n "$name" '.active_projects[] | select(endswith("/" + $n))' \
      "$ATLAS_CONFIG" &>/dev/null && return 0
  fi
  jq -e --arg t "$type" --arg n "$name" \
    '.pinned[]? | select(.type == $t and .name == $n)' \
    "$ATLAS_CONFIG" &>/dev/null
}

# Pin an entry
_atlas_pin() {
  local type="$1" name="$2"
  if _atlas_is_pinned "$type" "$name"; then
    echo "Already pinned: $type/$name"
    return 0
  fi
  local tmp=$(mktemp)
  jq --arg t "$type" --arg n "$name" \
    '.pinned = ((.pinned // []) + [{"type": $t, "name": $n}])' \
    "$ATLAS_CONFIG" > "$tmp" && mv "$tmp" "$ATLAS_CONFIG"
  echo "Pinned: $type/$name"
}

# Unpin an entry
_atlas_unpin() {
  local type="$1" name="$2"
  if ! _atlas_is_pinned "$type" "$name"; then
    echo "Not pinned: $type/$name"
    return 0
  fi
  # Can't unpin active_projects from here
  if [[ "$type" == "repo" ]]; then
    if jq -e --arg n "$name" '.active_projects[] | select(endswith("/" + $n))' \
      "$ATLAS_CONFIG" &>/dev/null; then
      echo "Cannot unpin active project (remove from active_projects in config)"
      return 1
    fi
  fi
  local tmp=$(mktemp)
  jq --arg t "$type" --arg n "$name" \
    '.pinned = [.pinned[]? | select(.type != $t or .name != $n)]' \
    "$ATLAS_CONFIG" > "$tmp" && mv "$tmp" "$ATLAS_CONFIG"
  echo "Unpinned: $type/$name"
}

map() {
  case "${1:-}" in
    --print|-p) _atlas_print ;;
    --json|-j)
      mkdir -p "$ATLAS_CACHE_DIR"
      local out
      out=$(_atlas_json)
      printf '%s\n' "$out"
      printf '%s' "$out" > "$ATLAS_CACHE_DIR/state.json"
      ;;
    pin)
      if [[ -z "${2:-}" || -z "${3:-}" ]]; then
        echo "Usage: map pin <type> <name>"
        echo "Types: github, remote, repo, dir"
        return 1
      fi
      _atlas_pin "$2" "$3"
      ;;
    unpin)
      if [[ -z "${2:-}" || -z "${3:-}" ]]; then
        echo "Usage: map unpin <type> <name>"
        return 1
      fi
      _atlas_unpin "$2" "$3"
      ;;
    config)     ${EDITOR:-nvim} "$ATLAS_CONFIG" ;;
    --help|-h)
      echo "Usage: map [section|name|--print|--json|pin|unpin|config]"
      echo ""
      echo "Sections: active, desktop, drive, github, icloud, remote"
      echo "Options:  --print  non-interactive overview"
      echo "          --json   structured JSON (also writes state.json)"
      echo "          pin      map pin <type> <name>"
      echo "          unpin    map unpin <type> <name>"
      echo "          config   edit classification config"
      ;;
    *) _atlas_browse "$1" ;;
  esac
}
