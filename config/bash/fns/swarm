# ==============================================================================
# Swarm: Agent-to-agent interaction system
# ==============================================================================
#
# Tracked swarms with messaging, output capture, and coordination topologies.
# Works locally (same machine, multiple panes) and distributed (Tailscale mesh).
#
# Topologies:
#   flat    - N equal workers, human orchestrates
#   star    - 1 conductor + N-1 workers, conductor delegates autonomously
#   pipe    - Sequential stages, each reads predecessor's output
#   pair    - Coder + reviewer feedback loop
#
# Usage:
#   swarm start 4 cx              # 4 local Claude agents (flat)
#   swarm star 4 cx               # conductor + 3 workers
#   swarm pipe 3 cx               # 3-stage pipeline
#   swarm pair cx                 # coder + reviewer
#   swarm mesh 3 cx               # distributed across Tailscale devices
#   swarm send agent-2 "do X"     # message a specific agent
#   swarm broadcast "do X"        # message all agents
#   swarm capture agent-1         # capture agent's pane output
#   swarm collect                 # aggregate all outputs
#   swarm status                  # show agent status table
#   swarm ls                      # list all swarms
#   swarm kill                    # tear down current swarm

# ------------------------------------------------------------------------------
# Internal helpers
# ------------------------------------------------------------------------------

_swarm_state_dir() {
  echo "$HOME/.local/share/omacmux/swarms"
}

# Get the swarm ID for the current window
_swarm_current_id() {
  tmux show-option -wqv @swarm_id 2>/dev/null
}

# Get the swarm state directory for the current window's swarm
_swarm_dir() {
  local id
  id=$(_swarm_current_id)
  [[ -z "$id" ]] && return 1
  echo "$(_swarm_state_dir)/$id"
}

# Resolve current pane to its agent ID
_swarm_whoami() {
  local current_pane="$TMUX_PANE"
  local pane_map
  pane_map=$(tmux show-option -wqv @swarm_panes 2>/dev/null)
  [[ -z "$pane_map" ]] && { echo "external"; return; }

  for entry in ${pane_map//,/ }; do
    local pane="${entry%%:*}"
    local agent="${entry#*:}"
    [[ "$pane" == "$current_pane" ]] && { echo "$agent"; return; }
  done
  echo "external"
}

# Resolve agent ID to its pane ID
_swarm_agent_pane() {
  local target="$1"
  local swarm_dir
  swarm_dir=$(_swarm_dir) || return 1

  local agent_file="$swarm_dir/agents/$target.json"
  [[ -f "$agent_file" ]] || return 1
  jq -r '.pane_id' "$agent_file"
}

# Resolve agent ID to its device name
_swarm_agent_device() {
  local target="$1"
  local swarm_dir
  swarm_dir=$(_swarm_dir) || return 1

  local agent_file="$swarm_dir/agents/$target.json"
  [[ -f "$agent_file" ]] || return 1
  jq -r '.device' "$agent_file"
}

# List agent IDs for a swarm directory (or current swarm)
_swarm_agent_ids() {
  local swarm_dir="${1:-$(_swarm_dir)}"
  [[ -z "$swarm_dir" ]] && return 1
  for f in "$swarm_dir/agents/"*.json; do
    [[ -f "$f" ]] || continue
    basename "$f" .json
  done
}

# Generate a short swarm ID
_swarm_gen_id() {
  date +%s | shasum | head -c 8
}

# Source path for FZF subshells
_swarm_src() {
  echo "${OMACMUX_PATH:-$HOME/.local/share/omacmux}/config/bash/fns/swarm"
}

# ANSI color constants
_swarm_colors() {
  _sw_green='\033[32m'
  _sw_dim='\033[2m'
  _sw_bold='\033[1m'
  _sw_cyan='\033[36m'
  _sw_orange='\033[38;5;172m'
  _sw_reset='\033[0m'
}

# Topology icon for a given topology name
_swarm_topo_icon() {
  case "$1" in
    star) echo "★" ;;
    pipe) echo "▸" ;;
    pair) echo "⇄" ;;
    mesh) echo "◆" ;;
    mixed) echo "⊞" ;;
    worktree|wt-star) echo "⌥" ;;
    *)    echo "·" ;;
  esac
}

# Check if an agent's pane is still alive
_swarm_pane_alive() {
  local agent="$1"
  local device pane
  device=$(_swarm_agent_device "$agent") || return 1
  pane=$(_swarm_agent_pane "$agent") || return 1

  if [[ "$device" == "local" ]]; then
    tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -qx "$pane"
  else
    return 0  # assume remote panes alive (can't cheaply check)
  fi
}

# ------------------------------------------------------------------------------
# Topology diagram
# ------------------------------------------------------------------------------

# Render topology diagram for a swarm
# Usage: _swarm_topology [swarm_dir]
_swarm_topology() {
  local swarm_dir="${1:-$(_swarm_dir)}"
  [[ -z "$swarm_dir" || ! -d "$swarm_dir" ]] && return 1

  _swarm_colors
  local topology
  topology=$(jq -r '.topology' "$swarm_dir/swarm.json")

  # Collect agent info
  local -a ids roles devices
  for f in "$swarm_dir/agents/"*.json; do
    [[ -f "$f" ]] || continue
    ids+=($(jq -r '.id' "$f"))
    roles+=($(jq -r '.role' "$f"))
    devices+=($(jq -r '.device' "$f"))
  done

  local n=${#ids[@]}
  (( n == 0 )) && return

  case "$topology" in
    star)
      # Tree style: conductor at root, workers as children
      local indicator
      if _swarm_pane_alive "${ids[0]}"; then
        indicator="${_sw_green}●${_sw_reset}"
      else
        indicator="${_sw_dim}○${_sw_reset}"
      fi
      printf "  ${indicator} ${_sw_bold}${_sw_cyan}%s${_sw_reset} (${_sw_orange}%s${_sw_reset})\n" "${ids[0]}" "${roles[0]}"

      for ((i=1; i<n; i++)); do
        if _swarm_pane_alive "${ids[$i]}"; then
          indicator="${_sw_green}●${_sw_reset}"
        else
          indicator="${_sw_dim}○${_sw_reset}"
        fi
        local branch="├──"
        (( i == n-1 )) && branch="└──"
        local dev_tag=""
        [[ "${devices[$i]}" != "local" ]] && dev_tag=", ${devices[$i]}"
        printf "  %s ${indicator} %s (%s%s)\n" "$branch" "${ids[$i]}" "${roles[$i]}" "$dev_tag"
      done
      ;;

    pipe)
      local line="  "
      for ((i=0; i<n; i++)); do
        local indicator
        if _swarm_pane_alive "${ids[$i]}"; then
          indicator="${_sw_green}●${_sw_reset}"
        else
          indicator="${_sw_dim}○${_sw_reset}"
        fi
        line+="${indicator} ${ids[$i]} (${roles[$i]})"
        (( i < n-1 )) && line+=" ${_sw_orange}──▶${_sw_reset} "
      done
      echo -e "$line"
      ;;

    pair)
      local ind1 ind2
      if _swarm_pane_alive "${ids[0]}"; then ind1="${_sw_green}●${_sw_reset}"; else ind1="${_sw_dim}○${_sw_reset}"; fi
      if _swarm_pane_alive "${ids[1]}"; then ind2="${_sw_green}●${_sw_reset}"; else ind2="${_sw_dim}○${_sw_reset}"; fi
      printf "  %b %s (%s) ${_sw_orange}◄──▶${_sw_reset} %b %s (%s)\n" \
        "$ind1" "${ids[0]}" "${roles[0]}" "$ind2" "${ids[1]}" "${roles[1]}"
      ;;

    *)
      # Flat / mesh: inline list
      local line="  "
      for ((i=0; i<n; i++)); do
        local indicator
        if _swarm_pane_alive "${ids[$i]}"; then
          indicator="${_sw_green}●${_sw_reset}"
        else
          indicator="${_sw_dim}○${_sw_reset}"
        fi
        local dev_tag=""
        [[ "${devices[$i]}" != "local" ]] && dev_tag=" @${devices[$i]}"
        line+="${indicator} ${ids[$i]}${dev_tag}   "
      done
      echo -e "$line"
      ;;
  esac
}

# ------------------------------------------------------------------------------
# Transport layer (unified local/remote)
# ------------------------------------------------------------------------------

# Send keystrokes to an agent's pane (local or remote via Tailscale)
_swarm_send_keys() {
  local agent="$1" && shift
  local text="$*"
  local device pane

  device=$(_swarm_agent_device "$agent") || return 1
  pane=$(_swarm_agent_pane "$agent") || return 1

  if [[ "$device" == "local" ]]; then
    tmux send-keys -t "$pane" "$text" C-m
  else
    tailscale ssh "$device" -- tmux send-keys -t "$pane" "$text" C-m
  fi
}

# Capture visible pane output from an agent (local or remote)
_swarm_capture_pane() {
  local agent="$1"
  local device pane

  device=$(_swarm_agent_device "$agent") || return 1
  pane=$(_swarm_agent_pane "$agent") || return 1

  if [[ "$device" == "local" ]]; then
    tmux capture-pane -t "$pane" -p
  else
    tailscale ssh "$device" -- tmux capture-pane -t "$pane" -p
  fi
}

# ------------------------------------------------------------------------------
# Swarm lifecycle
# ------------------------------------------------------------------------------

# Create a flat swarm: N local tiled panes running the same command
# Usage: swarm start <count> <command> [--name NAME]
_swarm_start() {
  local count="" cmd="" name=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *)
        if [[ -z "$count" ]]; then count="$1"
        elif [[ -z "$cmd" ]]; then cmd="$1"
        else echo "swarm start: unexpected arg '$1'"; return 1
        fi
        shift ;;
    esac
  done

  [[ -z "$count" || -z "$cmd" ]] && { echo "Usage: swarm start <count> <command> [--name NAME]"; return 1; }
  [[ -z $TMUX ]] && { echo "swarm start requires tmux."; return 1; }

  local swarm_id
  swarm_id=$(_swarm_gen_id)
  local swarm_dir="$(_swarm_state_dir)/$swarm_id"
  [[ -z "$name" ]] && name="swarm-$swarm_id"

  # Create state directories
  mkdir -p "$swarm_dir"/{agents,mailbox/shared,results}

  # Create tiled panes (reusing tsl pattern)
  local current_dir="${PWD}"
  local -a panes
  tmux rename-window -t "$TMUX_PANE" "$name"
  panes+=("$TMUX_PANE")

  while (( ${#panes[@]} < count )); do
    local new_pane
    local split_target="${panes[-1]}"
    new_pane=$(tmux split-window -h -t "$split_target" -c "$current_dir" -P -F '#{pane_id}')
    panes+=("$new_pane")
    tmux select-layout -t "${panes[0]}" tiled
  done

  # Register agents and build pane map
  local pane_map=""
  for ((i=0; i<${#panes[@]}; i++)); do
    local agent_id="agent-$((i+1))"
    local pane_id="${panes[$i]}"

    mkdir -p "$swarm_dir/mailbox/$agent_id"

    cat > "$swarm_dir/agents/$agent_id.json" <<EOF
{
  "id": "$agent_id",
  "pane_id": "$pane_id",
  "role": "worker",
  "command": "$cmd",
  "device": "local",
  "remote_pane": null,
  "status": "active",
  "started": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

    [[ -n "$pane_map" ]] && pane_map+=","
    pane_map+="$pane_id:$agent_id"
  done

  # Write swarm metadata
  local window_id
  window_id=$(tmux display-message -p '#{window_id}')
  local session
  session=$(tmux display-message -p '#{session_name}')

  cat > "$swarm_dir/swarm.json" <<EOF
{
  "id": "$swarm_id",
  "name": "$name",
  "topology": "flat",
  "hub": "local",
  "status": "running",
  "conductor": null,
  "working_dir": "$current_dir",
  "window_id": "$window_id",
  "session": "$session",
  "created": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "agents": [$(printf '"%s",' $(seq -f 'agent-%.0f' 1 ${#panes[@]}) | sed 's/,$//')]
}
EOF

  # Store on tmux window
  tmux set-option -w @swarm_id "$swarm_id"
  tmux set-option -w @swarm_panes "$pane_map"

  # Launch command in all panes
  for pane in "${panes[@]}"; do
    tmux send-keys -t "$pane" "$cmd" C-m
  done

  tmux select-pane -t "${panes[0]}"
  echo "swarm: created '$name' ($swarm_id) with ${#panes[@]} agents [flat]"
}

# Mixed swarm: different commands in count/command pairs
# Usage: swarm mixed <count1> <cmd1> [count2] [cmd2] ... [--name NAME]
# Example: swarm mixed 1 bash 2 cx --name hybrid
_swarm_mixed() {
  local -a counts cmds
  local name=""

  # Parse args: count/cmd pairs + optional --name
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *)
        if [[ "$1" =~ ^[0-9]+$ ]] && [[ $# -ge 2 && "$2" != "--name" ]]; then
          counts+=("$1")
          cmds+=("$2")
          shift 2
        else
          echo "swarm mixed: unexpected arg '$1'. Args must be count/command pairs."
          echo "Usage: swarm mixed <count1> <cmd1> [count2] [cmd2] ... [--name NAME]"
          return 1
        fi
        ;;
    esac
  done

  (( ${#cmds[@]} < 1 )) && { echo "Usage: swarm mixed <count1> <cmd1> [count2] [cmd2] ... [--name NAME]"; return 1; }
  [[ -z $TMUX ]] && { echo "swarm mixed requires tmux."; return 1; }

  # Calculate total
  local total=0
  for c in "${counts[@]}"; do (( total += c )); done
  (( total < 1 )) && { echo "swarm mixed: need at least 1 agent."; return 1; }

  local swarm_id
  swarm_id=$(_swarm_gen_id)
  local swarm_dir="$(_swarm_state_dir)/$swarm_id"
  [[ -z "$name" ]] && name="mixed-$swarm_id"

  mkdir -p "$swarm_dir"/{agents,mailbox/shared,results}

  # Create tiled panes
  local current_dir="${PWD}"
  local -a panes
  tmux rename-window -t "$TMUX_PANE" "$name"
  panes+=("$TMUX_PANE")

  while (( ${#panes[@]} < total )); do
    local new_pane split_target="${panes[-1]}"
    new_pane=$(tmux split-window -h -t "$split_target" -c "$current_dir" -P -F '#{pane_id}')
    panes+=("$new_pane")
    tmux select-layout -t "${panes[0]}" tiled
  done

  # Build command-per-pane mapping
  local -a pane_cmds
  for ((g=0; g<${#cmds[@]}; g++)); do
    for ((i=0; i<${counts[$g]}; i++)); do
      pane_cmds+=("${cmds[$g]}")
    done
  done

  # Register agents
  local pane_map=""
  for ((i=0; i<${#panes[@]}; i++)); do
    local agent_id="agent-$((i+1))"
    local pane_id="${panes[$i]}"
    local cmd="${pane_cmds[$i]}"

    mkdir -p "$swarm_dir/mailbox/$agent_id"

    cat > "$swarm_dir/agents/$agent_id.json" <<EOF
{
  "id": "$agent_id",
  "pane_id": "$pane_id",
  "role": "worker",
  "command": "$cmd",
  "device": "local",
  "remote_pane": null,
  "status": "active",
  "started": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

    [[ -n "$pane_map" ]] && pane_map+=","
    pane_map+="$pane_id:$agent_id"
  done

  # Write swarm metadata
  local window_id session
  window_id=$(tmux display-message -p '#{window_id}')
  session=$(tmux display-message -p '#{session_name}')

  local cmd_summary=""
  for ((g=0; g<${#cmds[@]}; g++)); do
    [[ -n "$cmd_summary" ]] && cmd_summary+=" + "
    cmd_summary+="${counts[$g]}×${cmds[$g]}"
  done

  cat > "$swarm_dir/swarm.json" <<EOF
{
  "id": "$swarm_id",
  "name": "$name",
  "topology": "mixed",
  "hub": "local",
  "status": "running",
  "conductor": null,
  "working_dir": "$current_dir",
  "window_id": "$window_id",
  "session": "$session",
  "created": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "agents": [$(printf '"%s",' $(seq -f 'agent-%.0f' 1 ${#panes[@]}) | sed 's/,$//')]
}
EOF

  tmux set-option -w @swarm_id "$swarm_id"
  tmux set-option -w @swarm_panes "$pane_map"

  # Launch commands per pane
  for ((i=0; i<${#panes[@]}; i++)); do
    tmux send-keys -t "${panes[$i]}" "${pane_cmds[$i]}" C-m
  done

  tmux select-pane -t "${panes[0]}"
  echo "swarm: created '$name' ($swarm_id) with $total agents [$cmd_summary]"
}

# Kill a swarm and clean up
# Usage: swarm kill [swarm_id|name]
# Resolve a swarm name or ID to its ID
_swarm_resolve_id() {
  local input="$1"
  local state_dir
  state_dir=$(_swarm_state_dir)

  # Direct ID match
  [[ -d "$state_dir/$input" ]] && { echo "$input"; return; }

  # Name match
  for swarm_file in "$state_dir"/*/swarm.json; do
    [[ -f "$swarm_file" ]] || continue
    local id name
    id=$(jq -r '.id' "$swarm_file")
    name=$(jq -r '.name' "$swarm_file")
    [[ "$name" == "$input" ]] && { echo "$id"; return; }
  done

  return 1
}

_swarm_kill() {
  local input="${1:-$(_swarm_current_id)}"
  [[ -z "$input" ]] && { echo "swarm kill: no active swarm in this window."; return 1; }

  local swarm_id
  swarm_id=$(_swarm_resolve_id "$input") || { echo "swarm kill: swarm '$input' not found."; return 1; }

  local swarm_dir="$(_swarm_state_dir)/$swarm_id"

  local name
  name=$(jq -r '.name // "unknown"' "$swarm_dir/swarm.json" 2>/dev/null)

  # Kill agent panes and clean up worktrees
  for agent_file in "$swarm_dir/agents/"*.json; do
    [[ -f "$agent_file" ]] || continue
    local device pane_id wt_dir wt_branch
    device=$(jq -r '.device' "$agent_file")
    pane_id=$(jq -r '.pane_id' "$agent_file")
    wt_dir=$(jq -r '.worktree // empty' "$agent_file")
    wt_branch=$(jq -r '.branch // empty' "$agent_file")

    # Kill pane
    if [[ "$device" == "local" ]]; then
      [[ "$pane_id" != "$TMUX_PANE" ]] && tmux kill-pane -t "$pane_id" 2>/dev/null
    else
      tailscale ssh "$device" -- tmux kill-pane -t "$pane_id" 2>/dev/null
    fi

    # Clean up worktree if it exists and isn't the main repo
    local main_dir
    main_dir=$(jq -r '.working_dir // empty' "$swarm_dir/swarm.json")
    if [[ -n "$wt_dir" && -d "$wt_dir" && "$wt_dir" != "$main_dir" ]]; then
      git worktree remove "$wt_dir" --force 2>/dev/null
      [[ -n "$wt_branch" ]] && git branch -D "$wt_branch" 2>/dev/null
    fi
  done

  # Clean up state
  rm -rf "$swarm_dir"

  # Clear window options if this is the current swarm
  if [[ "$swarm_id" == "$(_swarm_current_id)" ]]; then
    tmux set-option -wu @swarm_id 2>/dev/null
    tmux set-option -wu @swarm_panes 2>/dev/null
  fi

  echo "swarm: killed '$name' ($swarm_id)"
}

# List all active swarms with colored indicators
_swarm_ls() {
  local state_dir
  state_dir=$(_swarm_state_dir)

  if [[ ! -d "$state_dir" ]] || [[ -z "$(command ls -A "$state_dir" 2>/dev/null)" ]]; then
    echo "No active swarms."
    return
  fi

  _swarm_colors
  local current_id
  current_id=$(_swarm_current_id)

  printf "\n  ${_sw_bold}%-22s %-10s %-8s %-6s %-18s %s${_sw_reset}\n" \
    "NAME" "ID" "TOPOLOGY" "AGENTS" "CREATED" ""
  for swarm_file in "$state_dir"/*/swarm.json; do
    [[ -f "$swarm_file" ]] || continue
    local id name topology agent_count created window_id indicator suffix topo_icon
    id=$(jq -r '.id' "$swarm_file")
    name=$(jq -r '.name' "$swarm_file")
    topology=$(jq -r '.topology' "$swarm_file")
    agent_count=$(jq -r '.agents | length' "$swarm_file")
    created=$(jq -r '.created' "$swarm_file" | cut -c1-16)
    window_id=$(jq -r '.window_id' "$swarm_file")
    topo_icon=$(_swarm_topo_icon "$topology")

    # Check if window still exists
    if tmux list-windows -a -F '#{window_id}' 2>/dev/null | grep -qx "$window_id"; then
      indicator="${_sw_green}●${_sw_reset}"
    else
      indicator="${_sw_dim}○${_sw_reset}"
    fi

    suffix=""
    if [[ "$id" == "$current_id" ]]; then
      suffix="${_sw_dim}(this window)${_sw_reset}"
    fi

    printf "  ${indicator} %-22s ${_sw_dim}%-10s${_sw_reset} ${_sw_orange}%s${_sw_reset}%-5s %-6s %-18s %b\n" \
      "$name" "$id" "$topo_icon" "$topology" "$agent_count" "$created" "$suffix"
  done
  echo ""
}

# ------------------------------------------------------------------------------
# Communication
# ------------------------------------------------------------------------------

# Send a message to a specific agent (dual-channel: mailbox + pane injection)
# Usage: swarm send <agent-id> <message...>
_swarm_send() {
  local target="$1" && shift
  local message="$*"

  [[ -z "$target" || -z "$message" ]] && { echo "Usage: swarm send <agent-id> <message>"; return 1; }

  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm send: no active swarm in this window."; return 1; }

  # Validate target exists
  [[ -f "$swarm_dir/agents/$target.json" ]] || { echo "swarm send: agent '$target' not found."; return 1; }

  local sender
  sender=$(_swarm_whoami)

  # Write to mailbox (persistence)
  local mailbox="$swarm_dir/mailbox/$target"
  mkdir -p "$mailbox"
  local seq
  seq=$(find "$mailbox" -maxdepth 1 -name '*.msg' 2>/dev/null | wc -l | tr -d ' ')
  seq=$(printf "%03d" $((seq + 1)))

  cat > "$mailbox/$seq.msg" <<EOF
FROM: $sender
TO: $target
TIME: $(date -u +%Y-%m-%dT%H:%M:%SZ)
---
$message
EOF

  # Inject into pane (immediacy)
  _swarm_send_keys "$target" "$message"
  echo "swarm: sent to $target"
}

# Broadcast message to all agents in the current swarm
# Usage: swarm broadcast <message...>
_swarm_broadcast() {
  local message="$*"
  [[ -z "$message" ]] && { echo "Usage: swarm broadcast <message>"; return 1; }

  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm broadcast: no active swarm."; return 1; }

  local sender
  sender=$(_swarm_whoami)
  local count=0

  for agent_id in $(_swarm_agent_ids); do
    [[ "$agent_id" == "$sender" ]] && continue

    # Write to mailbox
    local mailbox="$swarm_dir/mailbox/$agent_id"
    mkdir -p "$mailbox"
    local seq
    seq=$(find "$mailbox" -maxdepth 1 -name '*.msg' 2>/dev/null | wc -l | tr -d ' ')
    seq=$(printf "%03d" $((seq + 1)))

    cat > "$mailbox/$seq.msg" <<EOF
FROM: $sender
TO: $agent_id
TIME: $(date -u +%Y-%m-%dT%H:%M:%SZ)
---
$message
EOF

    # Inject into pane
    _swarm_send_keys "$agent_id" "$message" 2>/dev/null && (( count++ ))
  done

  echo "swarm: broadcast to $count agent(s)."
}

# Read messages in an agent's mailbox
# Usage: swarm read [agent-id]
_swarm_read() {
  local target="${1:-$(_swarm_whoami)}"
  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm read: no active swarm."; return 1; }

  local mailbox="$swarm_dir/mailbox/$target"
  if [[ ! -d "$mailbox" ]] || ! compgen -G "$mailbox/*.msg" >/dev/null 2>&1; then
    echo "swarm: no messages for $target."
    return
  fi

  for msg in "$mailbox"/*.msg; do
    echo "--- $(basename "$msg") ---"
    cat "$msg"
    echo ""
  done
}

