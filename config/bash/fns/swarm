# Live-refreshing dashboard showing all agents' output
# Usage: swarm dashboard  (opens in popup)
_swarm_dashboard() {
  local swarm_id
  swarm_id=$(_swarm_current_id)
  [[ -z "$swarm_id" ]] && { echo "swarm dashboard: no active swarm."; return 1; }

  local swarm_dir="$(_swarm_state_dir)/$swarm_id"
  local src
  src=$(_swarm_src)

  # If not already in a popup, open one
  if [[ -z "$TMUX_POPUP" ]]; then
    tmux display-popup -E -w 85% -h 80% -T " swarm dashboard " \
      "TMUX_POPUP=1 bash -ic 'source \"$src\" && _swarm_dashboard'"
    return
  fi

  # Live refresh loop
  local swarm_name topology topo_icon
  swarm_name=$(jq -r '.name' "$swarm_dir/swarm.json")
  topology=$(jq -r '.topology' "$swarm_dir/swarm.json")
  topo_icon=$(_swarm_topo_icon "$topology")

  while true; do
    clear
    _swarm_colors

    printf "  ${_sw_bold}SWARM DASHBOARD${_sw_reset}: ${_sw_cyan}%s${_sw_reset}  ${_sw_orange}[%s %s]${_sw_reset}        ${_sw_dim}refreshed: %s${_sw_reset}\n" \
      "$swarm_name" "$topo_icon" "$topology" "$(date +%H:%M:%S)"
    echo "  ──────────────────────────────────────────────────────────────────"
    echo ""

    for agent_file in "$swarm_dir/agents/"*.json; do
      [[ -f "$agent_file" ]] || continue
      local agent_id role device pane_id indicator
      agent_id=$(jq -r '.id' "$agent_file")
      role=$(jq -r '.role' "$agent_file")
      device=$(jq -r '.device' "$agent_file")
      pane_id=$(jq -r '.pane_id' "$agent_file")

      if _swarm_pane_alive "$agent_id"; then
        indicator="${_sw_green}●${_sw_reset}"
      else
        indicator="${_sw_dim}○${_sw_reset}"
      fi

      local dev_tag=""
      [[ "$device" != "local" ]] && dev_tag=", $device"

      printf "  ${indicator} ${_sw_bold}${_sw_cyan}%s${_sw_reset} (%s%s)\n" "$agent_id" "$role" "$dev_tag"
      echo "  ──────────────────────────────"

      # Capture last 5 non-empty lines from the pane
      local output
      if [[ "$device" == "local" ]]; then
        output=$(tmux capture-pane -t "$pane_id" -p 2>/dev/null | grep -v '^$' | tail -5)
      else
        output=$(tailscale ssh "$device" -- tmux capture-pane -t "$pane_id" -p 2>/dev/null | grep -v '^$' | tail -5)
      fi

      if [[ -n "$output" ]]; then
        echo "$output" | while IFS= read -r line; do
          printf "  %s\n" "$line"
        done
      else
        printf "  ${_sw_dim}(no output)${_sw_reset}\n"
      fi
      echo ""
    done

    printf "  ${_sw_dim}[q] quit  [r] refresh  [c] collect results${_sw_reset}\n"

    read -t 5 -n 1 key 2>/dev/null
    case "$key" in
      q) break ;;
      c)
        _swarm_collect_by_id "$swarm_id" >/dev/null 2>&1
        echo "  Results collected."
        sleep 1
        ;;
    esac
  done
}

