# Capture an agent's visible pane output to results/
# Usage: swarm capture <agent-id>
_swarm_capture() {
  local agent="$1"
  [[ -z "$agent" ]] && { echo "Usage: swarm capture <agent-id>"; return 1; }

  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm capture: no active swarm."; return 1; }

  [[ -f "$swarm_dir/agents/$agent.json" ]] || { echo "swarm capture: agent '$agent' not found."; return 1; }

  _swarm_capture_pane "$agent" > "$swarm_dir/results/$agent.md"
  echo "swarm: captured $agent → results/$agent.md"
}

# Inspect an agent: capture pane output + show mailbox
# Usage: swarm inspect <agent-id>
_swarm_inspect() {
  local agent="$1"
  [[ -z "$agent" ]] && { echo "Usage: swarm inspect <agent-id>"; return 1; }

  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm inspect: no active swarm."; return 1; }
  [[ -f "$swarm_dir/agents/$agent.json" ]] || { echo "swarm inspect: agent '$agent' not found."; return 1; }

  _swarm_colors
  local role device cmd
  role=$(jq -r '.role' "$swarm_dir/agents/$agent.json")
  device=$(jq -r '.device' "$swarm_dir/agents/$agent.json")
  cmd=$(jq -r '.command' "$swarm_dir/agents/$agent.json")

  printf "\n  ${_sw_bold}${_sw_cyan}%s${_sw_reset}  %s · %s · %s\n" "$agent" "$role" "$cmd" "$device"
  echo "  ──────────────────────────────────────────────────"

  # Pane output
  printf "\n  ${_sw_bold}PANE OUTPUT${_sw_reset}\n"
  local output
  output=$(_swarm_capture_pane "$agent" 2>/dev/null | grep -v '^$' | tail -20)
  if [[ -n "$output" ]]; then
    echo "$output" | while IFS= read -r line; do printf "  %s\n" "$line"; done
  else
    printf "  ${_sw_dim}(no output)${_sw_reset}\n"
  fi

  # Save capture
  _swarm_capture_pane "$agent" > "$swarm_dir/results/$agent.md" 2>/dev/null

  # Mailbox
  local mailbox="$swarm_dir/mailbox/$agent"
  if compgen -G "$mailbox/*.msg" >/dev/null 2>&1; then
    printf "\n  ${_sw_bold}MAILBOX${_sw_reset}\n"
    for msg in "$mailbox"/*.msg; do
      local from time body
      from=$(head -1 "$msg" | sed 's/^FROM: //')
      time=$(sed -n '3p' "$msg" | sed 's/^TIME: //' | cut -c12-16)
      body=$(sed '1,/^---$/d' "$msg" | head -1 | cut -c1-60)
      printf "  ${_sw_dim}%s${_sw_reset}  %-12s %s\n" "$time" "$from" "$body"
    done
  else
    printf "\n  ${_sw_bold}MAILBOX${_sw_reset}\n"
    printf "  ${_sw_dim}(no messages)${_sw_reset}\n"
  fi
  echo ""
}

# Capture all agents and concatenate into summary.md
_swarm_collect() {
  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm collect: no active swarm."; return 1; }

  local count=0
  {
    echo "# Swarm Results"
    echo "Collected: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo ""

    for agent_id in $(_swarm_agent_ids); do
      local role device
      role=$(jq -r '.role' "$swarm_dir/agents/$agent_id.json")
      device=$(jq -r '.device' "$swarm_dir/agents/$agent_id.json")

      _swarm_capture_pane "$agent_id" > "$swarm_dir/results/$agent_id.md" 2>/dev/null

      echo "## $agent_id ($role, $device)"
      echo '```'
      cat "$swarm_dir/results/$agent_id.md" 2>/dev/null
      echo '```'
      echo ""
      (( count++ ))
    done
  } > "$swarm_dir/summary.md"

  echo "swarm: collected $count agent(s) → summary.md"
  echo "  $swarm_dir/summary.md"
}

# Show status of agents in the current swarm (or by ID)
# Usage: swarm status [swarm_id]
_swarm_status() {
  _swarm_status_by_id "${1:-$(_swarm_current_id)}"
}

# Render full status view for a given swarm ID
_swarm_status_by_id() {
  local swarm_id="$1"
  [[ -z "$swarm_id" ]] && { echo "swarm status: no active swarm in this window."; return 1; }

  local swarm_dir="$(_swarm_state_dir)/$swarm_id"
  [[ -d "$swarm_dir" ]] || { echo "swarm status: swarm '$swarm_id' not found."; return 1; }

  _swarm_colors

  local swarm_name topology agent_count topo_icon
  swarm_name=$(jq -r '.name' "$swarm_dir/swarm.json")
  topology=$(jq -r '.topology' "$swarm_dir/swarm.json")
  agent_count=$(jq -r '.agents | length' "$swarm_dir/swarm.json")
  topo_icon=$(_swarm_topo_icon "$topology")

  # Header
  printf "\n  ${_sw_bold}${_sw_cyan}%s${_sw_reset}  ${_sw_orange}[%s %s]${_sw_reset}  ·  %s agents\n" \
    "$swarm_name" "$topo_icon" "$topology" "$agent_count"
  echo "  ──────────────────────────────────────────────────"
  echo ""

  # Topology diagram
  printf "  ${_sw_bold}TOPOLOGY${_sw_reset}\n"
  _swarm_topology "$swarm_dir"
  echo ""

  # Agent table -- detect if this is a worktree swarm
  local has_worktrees=false
  local base_branch
  base_branch=$(jq -r '.base_branch // empty' "$swarm_dir/swarm.json")
  [[ -n "$base_branch" ]] && has_worktrees=true

  printf "  ${_sw_bold}AGENTS${_sw_reset}\n"
  if $has_worktrees; then
    printf "  ${_sw_bold}%-12s %-12s %-28s %s${_sw_reset}\n" \
      "AGENT" "ROLE" "BRANCH" "DIFF"
  else
    printf "  ${_sw_bold}%-12s %-12s %-10s %-8s %s${_sw_reset}\n" \
      "AGENT" "ROLE" "DEVICE" "PANE" "MSGS"
  fi

  for agent_id in $(_swarm_agent_ids "$swarm_dir"); do
    local role device pane_id msg_count indicator
    role=$(jq -r '.role' "$swarm_dir/agents/$agent_id.json")
    device=$(jq -r '.device' "$swarm_dir/agents/$agent_id.json")
    pane_id=$(jq -r '.pane_id' "$swarm_dir/agents/$agent_id.json")
    msg_count=$(find "$swarm_dir/mailbox/$agent_id" -maxdepth 1 -name '*.msg' 2>/dev/null | wc -l | tr -d ' ')

    if _swarm_pane_alive "$agent_id"; then
      indicator="${_sw_green}●${_sw_reset}"
    else
      indicator="${_sw_dim}○${_sw_reset}"
    fi

    if $has_worktrees; then
      local branch wt_dir diff_stat=""
      branch=$(jq -r '.branch // "--"' "$swarm_dir/agents/$agent_id.json")
      wt_dir=$(jq -r '.worktree // empty' "$swarm_dir/agents/$agent_id.json")
      if [[ -n "$wt_dir" && -d "$wt_dir" && "$branch" != "$base_branch" ]]; then
        local files_changed
        files_changed=$(cd "$wt_dir" && git diff --stat "$base_branch" 2>/dev/null | tail -1 | sed 's/^ *//')
        [[ -n "$files_changed" ]] && diff_stat="$files_changed"
      fi
      printf "  ${indicator} %-12s %-12s %-28s %s\n" \
        "$agent_id" "$role" "$branch" "${diff_stat:---}"
    else
      printf "  ${indicator} %-12s %-12s %-10s %-8s %s\n" \
        "$agent_id" "$role" "$device" "$pane_id" "$msg_count"
    fi
  done
  echo ""

  # Recent messages (last 5 across all mailboxes)
  local -a msg_lines
  for agent_id in $(_swarm_agent_ids "$swarm_dir"); do
    for msg_file in "$swarm_dir/mailbox/$agent_id"/*.msg; do
      [[ -f "$msg_file" ]] || continue
      local from to time body
      from=$(head -1 "$msg_file" | sed 's/^FROM: //')
      to=$(sed -n '2p' "$msg_file" | sed 's/^TO: //')
      time=$(sed -n '3p' "$msg_file" | sed 's/^TIME: //' | cut -c12-16)
      body=$(sed '1,/^---$/d' "$msg_file" | head -1 | cut -c1-50)
      local mtime
      mtime=$(stat -f %m "$msg_file" 2>/dev/null || stat -c %Y "$msg_file" 2>/dev/null)
      msg_lines+=("${mtime}|${from} → ${to}|${body}|${time}")
    done
  done

  if (( ${#msg_lines[@]} > 0 )); then
    printf "  ${_sw_bold}RECENT MESSAGES${_sw_reset}\n"
    printf '%s\n' "${msg_lines[@]}" | sort -t'|' -k1 -rn | head -5 | while IFS='|' read -r _ route body time; do
      printf "  ${_sw_dim}%s${_sw_reset}  %-24s %s\n" "$time" "$route" "$body"
    done
    echo ""
  fi
}

