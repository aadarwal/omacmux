# FZF swarm hub: browse all swarms with status preview
_swarm_hub() {
  local state_dir
  state_dir=$(_swarm_state_dir)
  [[ ! -d "$state_dir" ]] && { echo "No active swarms."; return; }

  local src
  src=$(_swarm_src)

  # Build TSV list of swarms
  local swarm_list=""
  for swarm_file in "$state_dir"/*/swarm.json; do
    [[ -f "$swarm_file" ]] || continue
    local id name topology agent_count created topo_icon
    id=$(jq -r '.id' "$swarm_file")
    name=$(jq -r '.name' "$swarm_file")
    topology=$(jq -r '.topology' "$swarm_file")
    agent_count=$(jq -r '.agents | length' "$swarm_file")
    created=$(jq -r '.created' "$swarm_file" | cut -c1-16)
    topo_icon=$(_swarm_topo_icon "$topology")
    swarm_list+="${id}\t${name}\t${topo_icon} ${topology}\t${agent_count} agents\t${created}\n"
  done

  [[ -z "$swarm_list" ]] && { echo "No active swarms."; return; }

  local selected
  selected=$(echo -e "$swarm_list" | \
    fzf --tmux 80%,70% \
      --header "enter: switch  ctrl-x: kill  ctrl-c: collect  ctrl-d: dashboard" \
      --delimiter $'\t' \
      --with-nth 2,3,4,5 \
      --preview "source '$src' && _swarm_status_by_id {1}" \
      --preview-window "right:55%" \
      --bind "ctrl-x:execute-silent(source '$src' && _swarm_kill {1})+reload(source '$src' && _swarm_hub_list)" \
      --bind "ctrl-c:execute(source '$src' && _swarm_collect_by_id {1})") || return 0

  local swarm_id window_id session
  swarm_id=$(echo "$selected" | cut -f1)
  [[ -z "$swarm_id" ]] && return 0

  local swarm_dir="$(_swarm_state_dir)/$swarm_id"
  window_id=$(jq -r '.window_id' "$swarm_dir/swarm.json")
  session=$(jq -r '.session' "$swarm_dir/swarm.json")

  # Switch to the swarm's window
  tmux select-window -t "$window_id" 2>/dev/null || \
    echo "swarm: window no longer exists."
}

# Helper for hub reload (outputs TSV)
_swarm_hub_list() {
  local state_dir="$HOME/.local/share/omacmux/swarms"
  for swarm_file in "$state_dir"/*/swarm.json; do
    [[ -f "$swarm_file" ]] || continue
    local id name topology agent_count created
    id=$(jq -r '.id' "$swarm_file")
    name=$(jq -r '.name' "$swarm_file")
    topology=$(jq -r '.topology' "$swarm_file")
    agent_count=$(jq -r '.agents | length' "$swarm_file")
    created=$(jq -r '.created' "$swarm_file" | cut -c1-16)
    local topo_icon
    case "$topology" in star) topo_icon="★";; pipe) topo_icon="▸";; pair) topo_icon="⇄";; mesh) topo_icon="◆";; *) topo_icon="·";; esac
    printf "%s\t%s\t%s %s\t%s agents\t%s\n" "$id" "$name" "$topo_icon" "$topology" "$agent_count" "$created"
  done
}

# Collect results for a specific swarm ID (used by hub)
_swarm_collect_by_id() {
  local swarm_id="$1"
  local swarm_dir="$HOME/.local/share/omacmux/swarms/$swarm_id"
  [[ -d "$swarm_dir" ]] || return 1

  local count=0
  {
    echo "# Swarm Results"
    echo "Collected: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo ""
    for agent_file in "$swarm_dir/agents/"*.json; do
      [[ -f "$agent_file" ]] || continue
      local agent_id role device pane_id
      agent_id=$(jq -r '.id' "$agent_file")
      role=$(jq -r '.role' "$agent_file")
      device=$(jq -r '.device' "$agent_file")
      pane_id=$(jq -r '.pane_id' "$agent_file")

      echo "## $agent_id ($role, $device)"
      echo '```'
      if [[ "$device" == "local" ]]; then
        tmux capture-pane -t "$pane_id" -p 2>/dev/null
      else
        tailscale ssh "$device" -- tmux capture-pane -t "$pane_id" -p 2>/dev/null
      fi
      echo '```'
      echo ""
      (( count++ ))
    done
  } > "$swarm_dir/summary.md"
  echo "swarm: collected $count agent(s) → $swarm_dir/summary.md"
}

# FZF agent picker: browse agents with live pane capture preview
_swarm_pick() {
  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm pick: no active swarm."; return 1; }

  local src
  src=$(_swarm_src)

  # Build TSV of agents
  local agent_list=""
  for agent_file in "$swarm_dir/agents/"*.json; do
    [[ -f "$agent_file" ]] || continue
    local agent_id role device pane_id
    agent_id=$(jq -r '.id' "$agent_file")
    role=$(jq -r '.role' "$agent_file")
    device=$(jq -r '.device' "$agent_file")
    pane_id=$(jq -r '.pane_id' "$agent_file")
    agent_list+="${agent_id}\t${role}\t${device}\t${pane_id}\n"
  done

  [[ -z "$agent_list" ]] && { echo "No agents."; return; }

  local selected
  selected=$(echo -e "$agent_list" | sort -V | \
    fzf --tmux 70%,60% \
      --header "enter: focus  ctrl-r: read mailbox  ctrl-c: capture" \
      --delimiter $'\t' \
      --with-nth 1,2,3 \
      --preview "
        device=\$(echo {} | cut -f3)
        pane=\$(echo {} | cut -f4)
        if [[ \"\$device\" == 'local' ]]; then
          tmux capture-pane -e -p -t \"\$pane\" 2>/dev/null || echo '(pane not available)'
        else
          tailscale ssh \"\$device\" -- tmux capture-pane -e -p -t \"\$pane\" 2>/dev/null || echo '(remote pane not available)'
        fi
      " \
      --preview-window "right:60%" \
      --bind "ctrl-r:execute(
        source '$src'
        agent=\$(echo {} | cut -f1)
        _swarm_read \"\$agent\" | less
      )" \
      --bind "ctrl-c:execute-silent(
        source '$src'
        agent=\$(echo {} | cut -f1)
        _swarm_capture \"\$agent\"
      )") || return 0

  local target_pane
  target_pane=$(echo "$selected" | cut -f4)
  [[ -n "$target_pane" ]] && tmux select-pane -t "$target_pane" 2>/dev/null
}

