# Bootstrap a conductor agent with swarm awareness
_swarm_bootstrap_conductor() {
  local agent_id="$1"
  local swarm_dir="$2"
  local swarm_id="$3"

  # Build worker list
  local workers=""
  for aid in $(_swarm_agent_ids); do
    [[ "$aid" == "$agent_id" ]] && continue
    local dev
    dev=$(jq -r '.device' "$swarm_dir/agents/$aid.json")
    [[ -n "$workers" ]] && workers+=", "
    workers+="$aid ($dev)"
  done

  local mailbox_base="$swarm_dir/mailbox"
  local results_base="$swarm_dir/results"

  local prompt="You are the conductor of a swarm of AI agents. Your job is to decompose tasks and delegate to workers by running bash commands.

WORKERS: $workers

IMPORTANT: To delegate a task, you MUST run this bash command for each worker:
$(for aid in $(_swarm_agent_ids "$swarm_dir"); do
    [[ "$aid" == "$agent_id" ]] && continue
    echo "  swarm send $aid \"YOUR TASK DESCRIPTION HERE\""
  done)

This delivers the task directly to the worker's terminal. You must actually run the command, not just describe it.

To check a worker's results: cat $results_base/<agent-id>.md
When all done, write the final synthesis to: $swarm_dir/summary.md

Now wait for a task. When you receive one, immediately decompose it and run the swarm send commands to delegate."

  _swarm_send_keys "$agent_id" "$prompt"
}

# Bootstrap a worker agent
_swarm_bootstrap_worker() {
  local agent_id="$1"
  local swarm_dir="$2"

  local prompt="You are $agent_id, a worker in a swarm. A conductor will send you tasks directly in this terminal. When you receive a task, execute it immediately. When done, write a summary of what you accomplished to: $swarm_dir/results/$agent_id.md"

  _swarm_send_keys "$agent_id" "$prompt"
}

# Bootstrap a pipeline stage
_swarm_bootstrap_stage() {
  local agent_id="$1"
  local stage_num="$2"
  local total_stages="$3"
  local swarm_dir="$4"
  local swarm_id="$5"

  local results="$swarm_dir/results"

  local prompt="You are stage $stage_num of $total_stages in a pipeline. IMPORTANT: You must use your tools to write files, not just respond with text."

  if (( stage_num == 1 )); then
    prompt+="

You are the FIRST stage. When you receive a task, do the work and then WRITE your output by running:
  cat > $results/$agent_id.md << 'RESULT'
  (your full output here)
  RESULT

You MUST run this command to write the file. The next stage cannot proceed without it."
  else
    local prev=$((stage_num - 1))
    prompt+="

WORKFLOW:
1. Read the previous stage's output by running: cat $results/agent-$prev.md
2. Do your work based on that input
3. WRITE your output by running: cat > $results/$agent_id.md << 'RESULT'
   (your full output here)
   RESULT

You MUST actually run these commands. Wait for instructions, then check for the previous stage's output."
  fi

  if (( stage_num == total_stages )); then
    prompt+=" You are the FINAL stage -- your output is the pipeline's final result."
  fi

  _swarm_send_keys "$agent_id" "$prompt"
}

# Bootstrap a review pair (coder or reviewer)
_swarm_bootstrap_pair() {
  local agent_id="$1"
  local role="$2"  # "coder" or "reviewer"
  local swarm_dir="$3"

  local prompt
  if [[ "$role" == "coder" ]]; then
    prompt="You are the CODER in a coder-reviewer pair. When you receive a task, implement it. When done, you MUST run this command to save your work summary:
  cat > $swarm_dir/results/$agent_id.md << 'RESULT'
  (describe what you built and where the files are)
  RESULT

Then run: swarm send agent-2 \"Code complete, please review. Summary in $swarm_dir/results/$agent_id.md\"

Wait for a task now."
  else
    prompt="You are the REVIEWER in a coder-reviewer pair. The coder will notify you when their work is ready.

When notified, review by running: cat $swarm_dir/results/agent-1.md
Then review the actual code files they mention. Write your feedback by running:
  swarm send agent-1 \"YOUR REVIEW FEEDBACK HERE\"

Also save your review: cat > $swarm_dir/results/$agent_id.md << 'RESULT'
(your review notes)
RESULT

Wait for the coder to notify you."
  fi

  _swarm_send_keys "$agent_id" "$prompt"
}

# Create a star topology swarm: 1 conductor + N-1 workers
# Usage: swarm star <count> <command> [--name NAME]
_swarm_star() {
  local count="" cmd="" name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *)
        if [[ -z "$count" ]]; then count="$1"
        elif [[ -z "$cmd" ]]; then cmd="$1"
        fi
        shift ;;
    esac
  done

  [[ -z "$count" || -z "$cmd" ]] && { echo "Usage: swarm star <count> <command> [--name NAME]"; return 1; }
  (( count < 2 )) && { echo "swarm star: need at least 2 agents (1 conductor + 1 worker)."; return 1; }

  # Create the flat swarm first
  _swarm_start "$count" "$cmd" ${name:+--name "$name"}

  local swarm_dir
  swarm_dir=$(_swarm_dir) || return 1
  local swarm_id
  swarm_id=$(_swarm_current_id)

  # Update topology and roles
  local tmp
  tmp=$(jq '.topology = "star" | .conductor = "agent-1"' "$swarm_dir/swarm.json")
  echo "$tmp" > "$swarm_dir/swarm.json"

  tmp=$(jq '.role = "conductor"' "$swarm_dir/agents/agent-1.json")
  echo "$tmp" > "$swarm_dir/agents/agent-1.json"

  # Wait for agents to start, then bootstrap
  sleep 4

  _swarm_bootstrap_conductor "agent-1" "$swarm_dir" "$swarm_id"

  for agent_id in $(_swarm_agent_ids); do
    [[ "$agent_id" == "agent-1" ]] && continue
    _swarm_bootstrap_worker "$agent_id" "$swarm_dir"
  done

  echo "swarm: topology set to star (agent-1 = conductor)"
}

# Create a pipeline topology swarm
# Usage: swarm pipe <count> <command> [--name NAME]
_swarm_pipe() {
  local count="" cmd="" name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *)
        if [[ -z "$count" ]]; then count="$1"
        elif [[ -z "$cmd" ]]; then cmd="$1"
        fi
        shift ;;
    esac
  done

  [[ -z "$count" || -z "$cmd" ]] && { echo "Usage: swarm pipe <count> <command> [--name NAME]"; return 1; }
  (( count < 2 )) && { echo "swarm pipe: need at least 2 stages."; return 1; }

  _swarm_start "$count" "$cmd" ${name:+--name "$name"}

  local swarm_dir
  swarm_dir=$(_swarm_dir) || return 1
  local swarm_id
  swarm_id=$(_swarm_current_id)

  # Update topology and roles
  local tmp
  tmp=$(jq '.topology = "pipe"' "$swarm_dir/swarm.json")
  echo "$tmp" > "$swarm_dir/swarm.json"

  for ((i=1; i<=count; i++)); do
    local agent_id="agent-$i"
    tmp=$(jq --arg r "stage-$i" '.role = $r' "$swarm_dir/agents/$agent_id.json")
    echo "$tmp" > "$swarm_dir/agents/$agent_id.json"
  done

  sleep 4

  for ((i=1; i<=count; i++)); do
    _swarm_bootstrap_stage "agent-$i" "$i" "$count" "$swarm_dir" "$swarm_id"
  done

  echo "swarm: topology set to pipe ($count stages)"
}

# Create a review pair: coder + reviewer
# Usage: swarm pair <command> [--name NAME]
_swarm_pair() {
  local cmd="" name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *)
        if [[ -z "$cmd" ]]; then cmd="$1"; fi
        shift ;;
    esac
  done

  [[ -z "$cmd" ]] && { echo "Usage: swarm pair <command> [--name NAME]"; return 1; }

  _swarm_start 2 "$cmd" ${name:+--name "$name"}

  local swarm_dir
  swarm_dir=$(_swarm_dir) || return 1

  # Update topology and roles
  local tmp
  tmp=$(jq '.topology = "pair"' "$swarm_dir/swarm.json")
  echo "$tmp" > "$swarm_dir/swarm.json"

  tmp=$(jq '.role = "coder"' "$swarm_dir/agents/agent-1.json")
  echo "$tmp" > "$swarm_dir/agents/agent-1.json"
  tmp=$(jq '.role = "reviewer"' "$swarm_dir/agents/agent-2.json")
  echo "$tmp" > "$swarm_dir/agents/agent-2.json"

  sleep 4

  _swarm_bootstrap_pair "agent-1" "coder" "$swarm_dir"
  _swarm_bootstrap_pair "agent-2" "reviewer" "$swarm_dir"

  echo "swarm: topology set to pair (agent-1 = coder, agent-2 = reviewer)"
}

# ------------------------------------------------------------------------------
# Distributed mesh swarm
# ------------------------------------------------------------------------------

# Create a swarm distributed across Tailscale mesh devices
# Usage: swarm mesh <count> <command> [--name NAME]
_swarm_mesh() {
  local count="" cmd="" name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      *)
        if [[ -z "$count" ]]; then count="$1"
        elif [[ -z "$cmd" ]]; then cmd="$1"
        fi
        shift ;;
    esac
  done

  [[ -z "$count" || -z "$cmd" ]] && { echo "Usage: swarm mesh <count> <command> [--name NAME]"; return 1; }
  [[ -z $TMUX ]] && { echo "swarm mesh requires tmux."; return 1; }

  # Check mesh functions are available
  command -v _mesh_picks &>/dev/null || { echo "swarm mesh: mesh system not available."; return 1; }

  # Pick devices
  echo "Select $count device(s) for the swarm:"
  local -a devices
  while IFS=$'\t' read -r dev_name _; do
    devices+=("$dev_name")
  done < <(_mesh_picks)

  if (( ${#devices[@]} < 1 )); then
    echo "swarm mesh: no devices selected."
    return 1
  fi

  local actual_count=${#devices[@]}
  local swarm_id
  swarm_id=$(_swarm_gen_id)
  local swarm_dir="$(_swarm_state_dir)/$swarm_id"
  [[ -z "$name" ]] && name="mesh-$swarm_id"

  mkdir -p "$swarm_dir"/{agents,mailbox/shared,results}

  local current_dir="${PWD}"
  local -a pane_ids
  local pane_map=""

  # First device gets current pane (or new pane)
  local main_pane="$TMUX_PANE"
  tmux rename-window -t "$main_pane" "$name"

  for ((i=0; i<${#devices[@]}; i++)); do
    local device="${devices[$i]}"
    local agent_id="agent-$((i+1))"
    local pane_id

    if (( i == 0 )); then
      # First agent: use a new split pane (keep current pane for user)
      pane_id=$(tmux split-window -h -t "$main_pane" -c "$current_dir" -P -F '#{pane_id}')
    else
      pane_id=$(tmux split-window -v -t "${pane_ids[-1]}" -c "$current_dir" -P -F '#{pane_id}')
    fi

    pane_ids+=("$pane_id")

    # Launch agent on device
    if _mesh_is_self "$device"; then
      tmux send-keys -t "$pane_id" "$cmd" C-m
    else
      tmux send-keys -t "$pane_id" "tailscale ssh $device -t '$cmd'" C-m
    fi

    # Register agent
    mkdir -p "$swarm_dir/mailbox/$agent_id"
    cat > "$swarm_dir/agents/$agent_id.json" <<EOF
{
  "id": "$agent_id",
  "pane_id": "$pane_id",
  "role": "worker",
  "command": "$cmd",
  "device": "$device",
  "remote_pane": null,
  "status": "active",
  "started": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

    [[ -n "$pane_map" ]] && pane_map+=","
    pane_map+="$pane_id:$agent_id"
  done

  tmux select-layout -t "$main_pane" tiled

  # Write swarm metadata
  local window_id session
  window_id=$(tmux display-message -p '#{window_id}')
  session=$(tmux display-message -p '#{session_name}')

  cat > "$swarm_dir/swarm.json" <<EOF
{
  "id": "$swarm_id",
  "name": "$name",
  "topology": "mesh",
  "hub": "local",
  "status": "running",
  "conductor": null,
  "working_dir": "$current_dir",
  "window_id": "$window_id",
  "session": "$session",
  "created": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "agents": [$(printf '"%s",' $(seq -f 'agent-%.0f' 1 ${#devices[@]}) | sed 's/,$//')]
}
EOF

  tmux set-option -w @swarm_id "$swarm_id"
  tmux set-option -w @swarm_panes "$pane_map"
  tmux select-pane -t "$main_pane"

  echo "swarm: created '$name' ($swarm_id) with $actual_count agent(s) across mesh"
  for ((i=0; i<${#devices[@]}; i++)); do
    echo "  agent-$((i+1)) → ${devices[$i]}"
  done
}

# ------------------------------------------------------------------------------
# Worktree-isolated swarms
# ------------------------------------------------------------------------------

# Create a swarm where each agent gets its own git worktree and branch
# Usage: swarm wt <count> <cmd> [--name NAME] [--star]
#   or:  swarm wt <cmd> <branch1> <branch2> ... [--name NAME] [--star]
_swarm_wt() {
  local count="" cmd="" name="" star=false
  local -a branches

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --star) star=true; shift ;;
      *)
        if [[ -z "$cmd" && "$1" =~ ^[0-9]+$ && $# -ge 2 ]]; then
          # count + cmd mode
          count="$1"; cmd="$2"; shift 2
        elif [[ -z "$cmd" ]]; then
          cmd="$1"; shift
        else
          # remaining args are branch names
          branches+=("$1"); shift
        fi
        ;;
    esac
  done

  [[ -z "$cmd" ]] && { echo "Usage: swarm wt <count> <cmd> [--name NAME] [--star]"; echo "   or: swarm wt <cmd> <branch1> <branch2> ..."; return 1; }
  [[ -z $TMUX ]] && { echo "swarm wt requires tmux."; return 1; }

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "swarm wt: not in a git repo."; return 1; }

  local base_branch
  base_branch=$(git rev-parse --abbrev-ref HEAD)

  # Determine agent count and branch names
  if (( ${#branches[@]} > 0 )); then
    count=${#branches[@]}
  else
    [[ -z "$count" ]] && { echo "swarm wt: provide a count or branch names."; return 1; }
    [[ -z "$name" ]] && name="wt-$(_swarm_gen_id)"
    for ((i=1; i<=count; i++)); do
      branches+=("swarm/$name/agent-$i")
    done
  fi

  local swarm_id
  swarm_id=$(_swarm_gen_id)
  local swarm_dir="$(_swarm_state_dir)/$swarm_id"
  [[ -z "$name" ]] && name="wt-$swarm_id"

  mkdir -p "$swarm_dir"/{agents,mailbox/shared,results}

  local current_dir="$PWD"
  local -a panes worktree_dirs
  tmux rename-window -t "$TMUX_PANE" "$name"

  # Create panes and worktrees
  local pane_map="" wt_pane_map=""
  local start_idx=0

  # In star mode, first agent (conductor) stays in main repo
  if $star; then
    panes+=("$TMUX_PANE")
    worktree_dirs+=("$repo_root")

    local agent_id="agent-1"
    mkdir -p "$swarm_dir/mailbox/$agent_id"
    cat > "$swarm_dir/agents/$agent_id.json" <<EOF
{
  "id": "$agent_id",
  "pane_id": "$TMUX_PANE",
  "role": "conductor",
  "command": "$cmd",
  "device": "local",
  "remote_pane": null,
  "status": "active",
  "worktree": "$repo_root",
  "branch": "$base_branch",
  "started": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
    pane_map="$TMUX_PANE:agent-1"
    wt_pane_map="$TMUX_PANE:$repo_root"
    start_idx=1
  fi

  for ((i=start_idx; i<count; i++)); do
    local branch="${branches[$i]}"
    local agent_id="agent-$((i+1))"
    local branch_slug="${branch//\//-}"
    local repo_name
    repo_name=$(basename "$repo_root")
    local wt_dir="$(dirname "$repo_root")/${repo_name}-${branch_slug}"

    # Create worktree
    if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
      git worktree add "$wt_dir" "$branch" 2>/dev/null
    else
      git worktree add -b "$branch" "$wt_dir" "$base_branch" 2>/dev/null
    fi

    if [[ ! -d "$wt_dir" ]]; then
      echo "swarm wt: failed to create worktree for $branch"
      continue
    fi

    worktree_dirs+=("$wt_dir")

    # Create pane (always split -- never steal user's pane)
    local pane_id
    local split_target="${panes[-1]:-$TMUX_PANE}"
    pane_id=$(tmux split-window -h -t "$split_target" -c "$wt_dir" -P -F '#{pane_id}')
    panes+=("$pane_id")
    tmux select-layout -t "${panes[0]:-$TMUX_PANE}" tiled

    # Register agent
    local role="worker"
    mkdir -p "$swarm_dir/mailbox/$agent_id"
    cat > "$swarm_dir/agents/$agent_id.json" <<EOF
{
  "id": "$agent_id",
  "pane_id": "$pane_id",
  "role": "$role",
  "command": "$cmd",
  "device": "local",
  "remote_pane": null,
  "status": "active",
  "worktree": "$wt_dir",
  "branch": "$branch",
  "started": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

    [[ -n "$pane_map" ]] && pane_map+=","
    pane_map+="$pane_id:$agent_id"
    [[ -n "$wt_pane_map" ]] && wt_pane_map+=","
    wt_pane_map+="$pane_id:$wt_dir"
  done

  # Write swarm metadata
  local window_id session topology="worktree"
  window_id=$(tmux display-message -p '#{window_id}')
  session=$(tmux display-message -p '#{session_name}')
  $star && topology="wt-star"

  local total=${#panes[@]}
  cat > "$swarm_dir/swarm.json" <<EOF
{
  "id": "$swarm_id",
  "name": "$name",
  "topology": "$topology",
  "hub": "local",
  "status": "running",
  "conductor": $($star && echo '"agent-1"' || echo 'null'),
  "working_dir": "$repo_root",
  "base_branch": "$base_branch",
  "window_id": "$window_id",
  "session": "$session",
  "created": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "agents": [$(printf '"%s",' $(seq -f 'agent-%.0f' 1 $total) | sed 's/,$//')]
}
EOF

  tmux set-option -w @swarm_id "$swarm_id"
  tmux set-option -w @swarm_panes "$pane_map"
  tmux set-option -w @wt_panes "$wt_pane_map"

  # Launch command in all panes
  for ((i=0; i<${#panes[@]}; i++)); do
    local pane="${panes[$i]}"
    local wt="${worktree_dirs[$i]}"
    # cd into worktree first, then launch
    tmux send-keys -t "$pane" "cd '$wt'" C-m
    tmux send-keys -t "$pane" "$cmd" C-m
  done

  tmux select-pane -t "${panes[0]}"

  # Bootstrap if star topology
  if $star; then
    sleep 4
    _swarm_bootstrap_conductor "agent-1" "$swarm_dir" "$swarm_id"
    for agent_id in $(_swarm_agent_ids "$swarm_dir"); do
      [[ "$agent_id" == "agent-1" ]] && continue
      _swarm_bootstrap_worker "$agent_id" "$swarm_dir"
    done
  fi

  echo "swarm: created '$name' ($swarm_id) with $total agents [worktree-isolated]"
  for ((i=0; i<${#panes[@]}; i++)); do
    local aid="agent-$((i+1))"
    local br
    br=$(jq -r '.branch' "$swarm_dir/agents/$aid.json" 2>/dev/null)
    echo "  $aid → $br"
  done
}

# Merge agent branches back to the base branch
# Usage: swarm merge [agent-id|--all|--pr]
_swarm_merge() {
  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm merge: no active swarm."; return 1; }

  local base_branch
  base_branch=$(jq -r '.base_branch // empty' "$swarm_dir/swarm.json")
  [[ -z "$base_branch" ]] && { echo "swarm merge: not a worktree swarm (no base_branch)."; return 1; }

  local repo_root
  repo_root=$(jq -r '.working_dir' "$swarm_dir/swarm.json")

  local mode="pick" target="" use_pr=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) mode="all"; shift ;;
      --pr)  use_pr=true; shift ;;
      *)     mode="single"; target="$1"; shift ;;
    esac
  done

  _swarm_colors

  # Collect mergeable agents (those with a branch that isn't the base)
  local -a merge_agents
  for agent_id in $(_swarm_agent_ids "$swarm_dir"); do
    local branch
    branch=$(jq -r '.branch // empty' "$swarm_dir/agents/$agent_id.json")
    [[ -z "$branch" || "$branch" == "$base_branch" ]] && continue
    merge_agents+=("$agent_id")
  done

  if (( ${#merge_agents[@]} == 0 )); then
    echo "swarm merge: no agent branches to merge."
    return
  fi

  # Pick targets
  local -a targets
  case "$mode" in
    single)
      [[ -f "$swarm_dir/agents/$target.json" ]] || { echo "swarm merge: agent '$target' not found."; return 1; }
      targets=("$target")
      ;;
    all)
      targets=("${merge_agents[@]}")
      ;;
    pick)
      local src
      src=$(_swarm_src)
      local agent_list=""
      for aid in "${merge_agents[@]}"; do
        local branch wt
        branch=$(jq -r '.branch' "$swarm_dir/agents/$aid.json")
        wt=$(jq -r '.worktree // "n/a"' "$swarm_dir/agents/$aid.json")
        agent_list+="$aid\t$branch\t$wt\n"
      done

      local selected
      selected=$(echo -e "$agent_list" | \
        fzf --tmux 70%,50% \
          --header "tab: multi-select  enter: merge" \
          --multi \
          --delimiter $'\t' \
          --preview "cd {3} 2>/dev/null && git diff --stat $base_branch" \
          --preview-window "right:50%") || return 0

      while IFS=$'\t' read -r aid _; do
        [[ -n "$aid" ]] && targets+=("$aid")
      done <<< "$selected"
      ;;
  esac

  (( ${#targets[@]} == 0 )) && return

  # Merge each target
  local merged=0
  for agent_id in "${targets[@]}"; do
    local branch wt_dir
    branch=$(jq -r '.branch' "$swarm_dir/agents/$agent_id.json")
    wt_dir=$(jq -r '.worktree // empty' "$swarm_dir/agents/$agent_id.json")

    printf "\n  ${_sw_bold}Merging${_sw_reset} %s (%s)\n" "$agent_id" "$branch"

    if $use_pr; then
      # Create PR
      (cd "$wt_dir" 2>/dev/null && git push -u origin "$branch" 2>/dev/null && \
        gh pr create --base "$base_branch" --head "$branch" \
          --title "swarm: $agent_id ($branch)" \
          --body "Auto-created by swarm merge from swarm agent $agent_id")
      echo "  PR created for $branch"
    else
      # Direct merge
      (cd "$repo_root" && git merge --no-ff "$branch" --no-edit 2>&1) || {
        echo "  ${_sw_bold}Conflict merging $branch.${_sw_reset} Aborting merge."
        (cd "$repo_root" && git merge --abort 2>/dev/null)
        return 1
      }
      echo "  Merged $branch into $base_branch"
    fi

    # Clean up worktree (skip for PR mode -- branch still needed on remote)
    if [[ -n "$wt_dir" && -d "$wt_dir" ]] && ! $use_pr; then
      git worktree remove "$wt_dir" 2>/dev/null
      git branch -d "$branch" 2>/dev/null
      echo "  Cleaned up worktree"
    fi

    # Update agent status
    local tmp
    tmp=$(jq '.status = "merged"' "$swarm_dir/agents/$agent_id.json")
    echo "$tmp" > "$swarm_dir/agents/$agent_id.json"
    (( merged++ ))
  done

  echo ""
  echo "swarm: merged $merged branch(es)."
}

# Check for merge conflicts between agent branches
# Usage: swarm conflicts
_swarm_conflicts() {
  local swarm_dir
  swarm_dir=$(_swarm_dir) || { echo "swarm conflicts: no active swarm."; return 1; }

  local base_branch
  base_branch=$(jq -r '.base_branch // empty' "$swarm_dir/swarm.json")
  [[ -z "$base_branch" ]] && { echo "swarm conflicts: not a worktree swarm."; return 1; }

  _swarm_colors

  # Collect branches
  local -a agent_ids agent_branches
  for agent_id in $(_swarm_agent_ids "$swarm_dir"); do
    local branch
    branch=$(jq -r '.branch // empty' "$swarm_dir/agents/$agent_id.json")
    [[ -z "$branch" || "$branch" == "$base_branch" ]] && continue
    agent_ids+=("$agent_id")
    agent_branches+=("$branch")
  done

  local n=${#agent_ids[@]}
  if (( n < 2 )); then
    echo "swarm conflicts: need at least 2 worktree agents to check."
    return
  fi

  printf "\n  ${_sw_bold}CONFLICT CHECK${_sw_reset} (vs $base_branch)\n"
  echo "  ──────────────────────────────────────────────────"

  local conflicts=0
  for ((i=0; i<n; i++)); do
    for ((j=i+1; j<n; j++)); do
      local a="${agent_branches[$i]}" b="${agent_branches[$j]}"
      local merge_base
      merge_base=$(git merge-base "$a" "$b" 2>/dev/null)
      if [[ -n "$merge_base" ]]; then
        local result
        result=$(git merge-tree "$merge_base" "$a" "$b" 2>/dev/null)
        if echo "$result" | grep -q "^<<<<<<<"; then
          printf "  ${_sw_orange}✗${_sw_reset} %s ↔ %s  ${_sw_orange}CONFLICT${_sw_reset}\n" "${agent_ids[$i]}" "${agent_ids[$j]}"
          (( conflicts++ ))
        else
          printf "  ${_sw_green}✓${_sw_reset} %s ↔ %s  clean\n" "${agent_ids[$i]}" "${agent_ids[$j]}"
        fi
      fi
    done
  done

  echo ""
  if (( conflicts > 0 )); then
    echo "  $conflicts conflict(s) detected. Consider merging sequentially."
  else
    echo "  No conflicts. Safe to merge in any order."
  fi
}

