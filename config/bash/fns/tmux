# ==============================================================================
# Session Management
# ==============================================================================

# Attach from outside tmux using a linked session group.
# Each terminal gets its own current-window pointer while sharing all windows.
# The linked session auto-destroys when the client detaches.
_t_attach() {
  local name="$1"
  local link="${name}~$$"
  tmux new-session -d -t "=$name" -s "$link"
  tmux set-option -t "=$link" destroy-unattached on
  tmux attach-session -t "=$link"
}

# Use the invoking client's PID when available so linked sessions stay bound
# to the terminal that requested the switch.
_t_client_pid() {
  local cpid="${1:-}"
  if [[ -n $cpid ]]; then
    printf '%s\n' "$cpid"
    return
  fi
  tmux display-message -p '#{client_pid}'
}

# Switch client inside tmux using a linked session group.
# Uses the tmux client PID so each terminal window gets a stable suffix.
_t_switch() {
  local name="$1"
  local cpid="${2-}"
  cpid=$(_t_client_pid "$cpid")
  local link="${name}~${cpid}"
  if ! tmux has-session -t "=$link" 2>/dev/null; then
    tmux new-session -d -t "=$name" -s "$link"
    tmux set-option -t "=$link" destroy-unattached on
  fi
  tmux switch-client -t "=$link"
}

# Switch to the next base session (wraps around)
_t_switch_next() {
  local current="${1:-}"
  local cpid="${2:-}"
  if [[ -z $current ]]; then
    current=$(tmux display-message -p '#S')
  fi
  current="${current%%~*}"

  local -a sessions
  while IFS= read -r s; do sessions+=("$s"); done \
    < <(tmux list-sessions -F '#S' | grep -v '^_stash$' | grep -v '~' | sort)
  local count=${#sessions[@]}
  (( count <= 1 )) && return

  local idx=0
  for ((i=0; i<count; i++)); do
    [[ ${sessions[$i]} == "$current" ]] && { idx=$i; break; }
  done
  _t_switch "${sessions[$(( (idx + 1) % count ))]}" "$cpid"
}

# Switch to the previous base session (wraps around)
_t_switch_prev() {
  local current="${1:-}"
  local cpid="${2:-}"
  if [[ -z $current ]]; then
    current=$(tmux display-message -p '#S')
  fi
  current="${current%%~*}"

  local -a sessions
  while IFS= read -r s; do sessions+=("$s"); done \
    < <(tmux list-sessions -F '#S' | grep -v '^_stash$' | grep -v '~' | sort)
  local count=${#sessions[@]}
  (( count <= 1 )) && return

  local idx=0
  for ((i=0; i<count; i++)); do
    [[ ${sessions[$i]} == "$current" ]] && { idx=$i; break; }
  done
  _t_switch "${sessions[$(( (idx - 1 + count) % count ))]}" "$cpid"
}

# Smart tmux entry point
# Usage:
#   t            -> outside tmux: attach last session or create "Work"
#                -> inside tmux: fzf session picker
#   t <name>     -> attach/switch to session, or create it
#   t <name> <dir> -> create session rooted at directory
#   t .          -> session named after current git repo (or directory)
t() {
  local name="$1"
  local dir="$2"

  # No arguments
  if [[ -z $name ]]; then
    if [[ -n $TMUX ]]; then
      tp
      return
    fi
    local _last
    _last=$(tmux list-sessions -F '#S' 2>/dev/null | grep -v '~' | head -1)
    if [[ -n $_last ]]; then
      _t_attach "$_last"
    else
      tmux new-session -s Work
    fi
    return
  fi

  # "t ." -- use git root or current dir as session name
  if [[ $name == "." ]]; then
    local root
    root=$(git rev-parse --show-toplevel 2>/dev/null) || root="$PWD"
    name=$(basename "$root" | tr '.:' '--')
    dir="$root"
  fi

  # Resolve directory (support zoxide fuzzy matching)
  if [[ -n $dir && ! -d $dir ]] && command -v zoxide &>/dev/null; then
    dir=$(zoxide query -- "$dir" 2>/dev/null) || { echo "Directory not found: $2"; return 1; }
  fi

  # If session exists, attach/switch to it
  if tmux has-session -t "=$name" 2>/dev/null; then
    if [[ -n $TMUX ]]; then
      _t_switch "$name"
    else
      _t_attach "$name"
    fi
    return
  fi

  # Create new session
  local new_dir="${dir:-$PWD}"
  if [[ -n $TMUX ]]; then
    tmux new-session -d -s "$name" -c "$new_dir"
    _t_switch "$name"
  else
    tmux new-session -s "$name" -c "$new_dir"
  fi

  # Source workspace config if present
  if [[ -f "$new_dir/.tmux-workspace" ]]; then
    source "$new_dir/.tmux-workspace"
  fi
}

# Create a new named session (errors if it already exists)
# Usage: tn <name> [directory]
tn() {
  local name="$1"
  local dir="${2:-$PWD}"

  [[ -z $name ]] && { echo "Usage: tn <name> [directory]"; return 1; }

  if tmux has-session -t "=$name" 2>/dev/null; then
    echo "Session '$name' already exists. Use 't $name' to switch."
    return 1
  fi

  if [[ -n $TMUX ]]; then
    tmux new-session -d -s "$name" -c "$dir"
    _t_switch "$name"
  else
    tmux new-session -s "$name" -c "$dir"
  fi
}

# Kill a tmux session (current session if no argument)
# Usage: tk [session_name]
tk() {
  local name="${1:-$(tmux display-message -p '#S' 2>/dev/null)}"
  name="${name%%~*}"  # normalize grouped session name to base
  [[ -z $name ]] && { echo "Usage: tk [session_name]"; return 1; }

  # Kill linked group sessions first, then the base session
  tmux list-sessions -F '#S' 2>/dev/null | grep "^${name}~" | while read -r s; do
    tmux kill-session -t "=$s" 2>/dev/null
  done
  tmux kill-session -t "=$name" 2>/dev/null && echo "Killed session '$name'" || echo "Session '$name' not found."
}

# List all tmux sessions
tl() {
  tmux list-sessions 2>/dev/null | grep -v '~' || echo "No tmux sessions running."
}

# fzf session picker/switcher
# Inside tmux: switch session. Outside: attach. ctrl-x to kill inline.
tp() {
  [[ -z $(tmux list-sessions 2>/dev/null) ]] && { echo "No tmux sessions."; return 1; }

  local fmt='#{session_name}: #{session_windows} windows#{?session_attached, (attached),}'
  local selected
  selected=$(tmux list-sessions -F "$fmt" | grep -v '^_stash:' | grep -v '~' | fzf --tmux 60%,40% \
    --header "ctrl-x: kill  enter: switch" \
    --bind "ctrl-x:execute-silent(tmux kill-session -t {1})+reload(tmux list-sessions -F \"$fmt\" 2>/dev/null | grep -v '^_stash:' | grep -v '~' || true)" \
    --delimiter ":" \
    --preview "tmux capture-pane -e -p -t {1}:" \
    --preview-window "right:60%") || return 0

  local session_name="${selected%%:*}"

  if [[ -n $TMUX ]]; then
    _t_switch "$session_name"
  else
    _t_attach "$session_name"
  fi
}

# ==============================================================================
# Project Awareness
# ==============================================================================

# Jump to a project directory: fzf pick from zoxide, create/attach session
# Usage: tj [query]
tj() {
  local query="$1"
  local selected

  if ! command -v zoxide &>/dev/null; then
    echo "tj requires zoxide."
    return 1
  fi

  if [[ -n $query ]]; then
    selected=$(zoxide query -- "$query" 2>/dev/null)
  else
    selected=$(zoxide query -l 2>/dev/null | fzf --tmux 70%,50% \
      --header "Pick a project directory" \
      --preview "ls -la {}" \
      --scheme path) || return 0
  fi

  [[ -z $selected ]] && { echo "No directory selected."; return 1; }

  local name
  name=$(basename "$selected" | tr '.:' '--')

  t "$name" "$selected"
}

# ==============================================================================
# Window Management
# ==============================================================================

# Create a named window (optionally with a command and directory)
# Usage: tw <name> [command] [directory]
tw() {
  local name="$1"
  local cmd="$2"
  local dir="${3:-$(tmux display-message -p '#{pane_current_path}' 2>/dev/null)}"

  [[ -z $TMUX ]] && { echo "tw requires tmux."; return 1; }
  [[ -z $name ]] && { echo "Usage: tw <name> [command] [directory]"; return 1; }

  local pane_id
  pane_id=$(tmux new-window -c "${dir:-$PWD}" -n "$name" -P -F '#{pane_id}')

  if [[ -n $cmd ]]; then
    tmux send-keys -t "$pane_id" "$cmd" C-m
  fi
}

# fzf window picker
twp() {
  [[ -z $TMUX ]] && { echo "twp requires tmux."; return 1; }

  local fmt="#{window_index}: #{window_name} (#{window_panes} panes)#{?window_active, *,}"
  local selected
  selected=$(tmux list-windows -F "$fmt" | fzf --tmux 50%,40% \
    --header "Pick a window" \
    --preview "tmux capture-pane -e -p -t :{1}" \
    --delimiter ":") || return 0

  local idx="${selected%%:*}"
  tmux select-window -t ":$idx"
}

# Popup overlay/scratchpad
# Usage: to [command]
to() {
  [[ -z $TMUX ]] && { echo "to requires tmux."; return 1; }
  local cmd="${1:-$SHELL}"
  tmux display-popup -E -w 80% -h 75% -d "#{pane_current_path}" "$cmd"
}

# Stash current window (move to _stash session for later retrieval)
# Usage: tws [session:window]  (auto-detected if omitted)
tws() {
  local target="$1"

  if [[ -z $target ]]; then
    [[ -z $TMUX ]] && { echo "tws requires tmux."; return 1; }
    target=$(tmux display-message -p '#S:#I')
  fi

  local session="${target%%:*}"
  [[ $session == "_stash" ]] && { echo "Already in stash."; return 1; }

  # Tag window with origin session
  tmux set-option -w -t "$target" @stash_origin "$session"

  # Ensure _stash session exists
  if ! tmux has-session -t =_stash 2>/dev/null; then
    tmux new-session -d -s _stash
    local placeholder
    placeholder=$(tmux list-windows -t _stash -F '#{window_id}' | head -1)
    tmux move-window -s "$target" -t _stash:
    tmux kill-window -t "$placeholder"
  else
    tmux move-window -s "$target" -t _stash:
  fi
}

# Grab a window back from the stash (fzf picker)
# Usage: twg
twg() {
  [[ -z $TMUX ]] && { echo "twg requires tmux."; return 1; }

  if ! tmux has-session -t =_stash 2>/dev/null; then
    echo "Stash is empty."
    return 1
  fi

  local fmt='#{window_index}: #{window_name} (from: #{@stash_origin})'
  local selected
  selected=$(tmux list-windows -t _stash -F "$fmt" | sort -t: -k1 -rn | fzf --reverse \
    --no-sort \
    --header "Grab from stash" \
    --preview "tmux capture-pane -e -p -t _stash:{1}" \
    --delimiter ":") || return 0

  local idx="${selected%%:*}"
  local target
  target=$(tmux display-message -p '#S')

  tmux move-window -s "_stash:$idx" -t "$target:"

  # Clean up empty stash session
  if [[ -z $(tmux list-windows -t _stash 2>/dev/null) ]]; then
    tmux kill-session -t =_stash 2>/dev/null
  fi
}

