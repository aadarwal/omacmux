# AI in a popup
# Usage: ta [initial_text]
ta() {
  [[ -z $TMUX ]] && { echo "ta requires tmux."; return 1; }
  if [[ -n $1 ]]; then
    tmux display-popup -E -w 80% -h 75% -d "#{pane_current_path}" "claude \"$*\""
  else
    tmux display-popup -E -w 80% -h 75% -d "#{pane_current_path}" "claude"
  fi
}

# Broadcast text to all panes in current window (skips current pane)
# Usage: tsb <text>
tsb() {
  [[ -z $1 ]] && { echo "Usage: tsb <text>"; return 1; }
  [[ -z $TMUX ]] && { echo "tsb requires tmux."; return 1; }

  local current_pane="$TMUX_PANE"
  local panes
  panes=$(tmux list-panes -F '#{pane_id}')

  for pane in $panes; do
    [[ $pane == "$current_pane" ]] && continue
    tmux send-keys -t "$pane" "$*" C-m
  done
}

# Broadcast text to all panes across ALL windows in session
# Usage: tsa <text>
tsa() {
  [[ -z $1 ]] && { echo "Usage: tsa <text>"; return 1; }
  [[ -z $TMUX ]] && { echo "tsa requires tmux."; return 1; }

  local current_pane="$TMUX_PANE"
  local panes
  panes=$(tmux list-panes -a -F '#{pane_id}' -f '#{==:#{session_name},#{client_session}}')

  for pane in $panes; do
    [[ $pane == "$current_pane" ]] && continue
    tmux send-keys -t "$pane" "$*" C-m
  done
}

# ==============================================================================
# Layouts
# ==============================================================================

# Dev Layout: editor + AI + terminal
# Usage: tdl <ai> [<second_ai>]
# Proportions configurable via TDL_AI_WIDTH (default 30) and TDL_TERMINAL_HEIGHT (default 15)
tdl() {
  [[ -z $1 ]] && { echo "Usage: tdl <c|cx|codex|other_ai> [<second_ai>]"; return 1; }
  [[ -z $TMUX ]] && { echo "You must start tmux to use tdl."; return 1; }

  local current_dir="${PWD}"
  local editor_pane ai_pane ai2_pane
  local ai="$1"
  local ai2="$2"
  local ai_width="${TDL_AI_WIDTH:-30}"
  local terminal_height="${TDL_TERMINAL_HEIGHT:-15}"

  editor_pane="$TMUX_PANE"

  tmux rename-window -t "$editor_pane" "$(basename "$current_dir")"

  # Bottom terminal
  tmux split-window -v -p "$terminal_height" -t "$editor_pane" -c "$current_dir"

  # AI on right
  ai_pane=$(tmux split-window -h -p "$ai_width" -t "$editor_pane" -c "$current_dir" -P -F '#{pane_id}')

  # Optional second AI
  if [[ -n $ai2 ]]; then
    ai2_pane=$(tmux split-window -v -t "$ai_pane" -c "$current_dir" -P -F '#{pane_id}')
    tmux send-keys -t "$ai2_pane" "$ai2" C-m
  fi

  tmux send-keys -t "$ai_pane" "$ai" C-m
  tmux send-keys -t "$editor_pane" "$EDITOR ." C-m
  tmux select-pane -t "$editor_pane"
}

# Multi-project Dev Layout: one tdl window per subdirectory
# Usage: tdlm <ai> [<second_ai>]
tdlm() {
  [[ -z $1 ]] && { echo "Usage: tdlm <c|cx|codex|other_ai> [<second_ai>]"; return 1; }
  [[ -z $TMUX ]] && { echo "You must start tmux to use tdlm."; return 1; }

  local ai="$1"
  local ai2="$2"
  local base_dir="$PWD"
  local first=true

  tmux rename-session "$(basename "$base_dir" | tr '.:' '--')"

  for dir in "$base_dir"/*/; do
    [[ -d $dir ]] || continue
    local dirpath="${dir%/}"

    if $first; then
      tmux send-keys -t "$TMUX_PANE" "cd '$dirpath' && tdl $ai $ai2" C-m
      first=false
    else
      local pane_id=$(tmux new-window -c "$dirpath" -P -F '#{pane_id}')
      tmux send-keys -t "$pane_id" "tdl $ai $ai2" C-m
    fi
  done
}

# Swarm Layout: N tiled panes all running the same command
# Usage: tsl <pane_count> <command>
tsl() {
  [[ -z $1 || -z $2 ]] && { echo "Usage: tsl <pane_count> <command>"; return 1; }
  [[ -z $TMUX ]] && { echo "You must start tmux to use tsl."; return 1; }

  local count="$1"
  local cmd="$2"
  local current_dir="${PWD}"
  local -a panes

  tmux rename-window -t "$TMUX_PANE" "$(basename "$current_dir")"

  panes+=("$TMUX_PANE")

  while (( ${#panes[@]} < count )); do
    local new_pane
    local split_target="${panes[-1]}"
    new_pane=$(tmux split-window -h -t "$split_target" -c "$current_dir" -P -F '#{pane_id}')
    panes+=("$new_pane")
    tmux select-layout -t "${panes[0]}" tiled
  done

  for pane in "${panes[@]}"; do
    tmux send-keys -t "$pane" "$cmd" C-m
  done

  tmux select-pane -t "${panes[0]}"
}

# Mixed Swarm Layout: tiled panes with different commands
# Usage: tslm <count1> <cmd1> [count2] [cmd2] ...
# Example: tslm 4 cx 4 codex   (4 claude + 4 codex = 8 panes)
tslm() {
  (( $# < 2 )) && { echo "Usage: tslm <count1> <cmd1> [count2] [cmd2] ..."; return 1; }
  (( $# % 2 != 0 )) && { echo "Args must be count/command pairs: tslm 4 cx 4 codex"; return 1; }
  [[ -z $TMUX ]] && { echo "You must start tmux to use tslm."; return 1; }

  local current_dir="${PWD}"
  local -a counts cmds

  # Parse count/command pairs
  while (( $# >= 2 )); do
    counts+=("$1")
    cmds+=("$2")
    shift 2
  done

  # Calculate total panes
  local total=0
  for c in "${counts[@]}"; do
    (( total += c ))
  done

  # Create all panes
  local -a panes
  tmux rename-window -t "$TMUX_PANE" "$(basename "$current_dir")"
  panes+=("$TMUX_PANE")

  while (( ${#panes[@]} < total )); do
    local new_pane
    local split_target="${panes[-1]}"
    new_pane=$(tmux split-window -h -t "$split_target" -c "$current_dir" -P -F '#{pane_id}')
    panes+=("$new_pane")
    tmux select-layout -t "${panes[0]}" tiled
  done

  # Assign commands in groups
  local idx=0
  for ((g=0; g<${#cmds[@]}; g++)); do
    for ((i=0; i<${counts[$g]}; i++)); do
      tmux send-keys -t "${panes[$idx]}" "${cmds[$g]}" C-m
      (( idx++ ))
    done
  done

  tmux select-pane -t "${panes[0]}"
}

# Pair Layout: two editors side by side + terminal at bottom
# Usage: tpl [directory]
tpl() {
  [[ -z $TMUX ]] && { echo "tpl requires tmux."; return 1; }

  local dir="${1:-$PWD}"
  local main_pane="$TMUX_PANE"

  tmux rename-window -t "$main_pane" "$(basename "$dir")"

  # Bottom terminal 15%
  tmux split-window -v -p 15 -t "$main_pane" -c "$dir"

  # Right editor 50%
  local right_pane
  right_pane=$(tmux split-window -h -p 50 -t "$main_pane" -c "$dir" -P -F '#{pane_id}')

  tmux send-keys -t "$main_pane" "$EDITOR ." C-m
  tmux send-keys -t "$right_pane" "$EDITOR ." C-m
  tmux select-pane -t "$main_pane"
}

# Monitor Layout: main pane left + stacked command panes on right
# Usage: tml <cmd1> [cmd2] [cmd3] ...
tml() {
  [[ $# -eq 0 ]] && { echo "Usage: tml <cmd1> [cmd2] [cmd3] ..."; return 1; }
  [[ -z $TMUX ]] && { echo "tml requires tmux."; return 1; }

  local dir="$PWD"
  local main_pane="$TMUX_PANE"

  tmux rename-window -t "$main_pane" "$(basename "$dir")"

  # First command gets a right pane at 30%
  local side_pane
  side_pane=$(tmux split-window -h -p 30 -t "$main_pane" -c "$dir" -P -F '#{pane_id}')
  tmux send-keys -t "$side_pane" "$1" C-m
  shift

  # Remaining commands stack vertically in the right column
  local prev="$side_pane"
  for cmd in "$@"; do
    local new_pane
    new_pane=$(tmux split-window -v -t "$prev" -c "$dir" -P -F '#{pane_id}')
    tmux send-keys -t "$new_pane" "$cmd" C-m
    prev="$new_pane"
  done

  tmux select-pane -t "$main_pane"
}

# ==============================================================================
# Persistence
# ==============================================================================

# Save current tmux state (session/window/pane directories)
# Usage: tss [name]
tss() {
  local save_name="${1:-default}"
  local save_dir="$HOME/.local/share/omacmux/sessions"
  local save_file="$save_dir/$save_name.tsv"

  mkdir -p "$save_dir"

  tmux list-panes -a -F "#{session_name}	#{window_index}	#{window_name}	#{pane_index}	#{pane_current_path}	#{pane_current_command}" > "$save_file"

  echo "Saved tmux state to $save_file ($(wc -l < "$save_file" | tr -d ' ') panes)"
}

# Restore tmux state from a save file
# Usage: tsr [name]
tsr() {
  local save_name="${1:-default}"
  local save_dir="$HOME/.local/share/omacmux/sessions"
  local save_file="$save_dir/$save_name.tsv"

  [[ ! -f $save_file ]] && { echo "No save file: $save_file"; return 1; }

  local current_session=""
  local current_window=""

  while IFS=$'\t' read -r session window_idx window_name pane_idx pane_dir pane_cmd; do
    # Create session if new
    if [[ $session != "$current_session" ]]; then
      if ! tmux has-session -t "=$session" 2>/dev/null; then
        tmux new-session -d -s "$session" -c "$pane_dir"
        tmux rename-window -t "$session:1" "$window_name"
      fi
      current_session="$session"
      current_window="$window_idx"
      continue
    fi

    # Create window if new
    if [[ $window_idx != "$current_window" ]]; then
      tmux new-window -t "$session:" -n "$window_name" -c "$pane_dir"
      current_window="$window_idx"
      continue
    fi

    # Additional pane in current window
    tmux split-window -t "$session:$window_idx" -c "$pane_dir"
    tmux select-layout -t "$session:$window_idx" tiled
  done < "$save_file"

  echo "Restored from $save_file"
}
