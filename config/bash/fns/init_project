# ==============================================================================
# Init Project — Generate AGENTS.md with AI-powered repo analysis
# ==============================================================================
#
# Profiles the current repo, sends the profile to Claude for analysis, and
# generates an AGENTS.md file with architecture summary, suggested workflows,
# and swarm topology guidance.
#
# Usage:
#   anu_init              # generate AGENTS.md for current repo
#   anu_init --force      # regenerate even if AGENTS.md exists

# ------------------------------------------------------------------------------
# Constants & stub guards
# ------------------------------------------------------------------------------

_init_state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/anu/init"
command -v _voice_say &>/dev/null || _voice_say() { :; }
command -v _voice_sound &>/dev/null || _voice_sound() { :; }

# ------------------------------------------------------------------------------
# Internal helpers
# ------------------------------------------------------------------------------

_init_profile_repo() {
  local output="$1"
  local git_root
  git_root=$(git rev-parse --show-toplevel 2>/dev/null) || return 1
  local repo_name
  repo_name=$(basename "$git_root")

  local file_list
  file_list=$(mktemp)
  git ls-files > "$file_list"
  local total_files
  total_files=$(wc -l < "$file_list" | tr -d ' ')

  {
    echo "# Codebase Profile: $repo_name"
    echo ""
    echo "- **Remote:** $(git remote get-url origin 2>/dev/null || echo '(none)')"
    echo "- **Total files:** $total_files"
    echo ""

    echo "## Languages"
    echo ""
    sed -n 's/.*\.//p' "$file_list" | sort | uniq -c | sort -rn | head -20 | while read -r count ext; do
      printf '%s\n' "- .$ext: $count files"
    done
    echo ""

    echo "## Directory Structure"
    echo '```'
    find "$git_root" -maxdepth 2 -type d ! -name '.git' ! -path '*/.git/*' | sed "s|$git_root|.|" | sort
    echo '```'
    echo ""

    if [[ -f "$git_root/README.md" ]]; then
      echo "## README (excerpt)"
      echo ""
      head -50 "$git_root/README.md" 2>/dev/null
      echo ""
    fi

    echo "## Recent Commits"
    echo '```'
    git log --oneline -10
    echo '```'
  } > "$output"

  rm -f "$file_list"
  echo -e "\033[36minit:\033[0m profiled $repo_name ($total_files files)"
}

_init_generate_agents_md() {
  local profile_path="$1"
  local output_path="$2"
  local profile
  profile=$(cat "$profile_path") || return 1

  local result
  result=$(claude --print --allowedTools "" -p "You are an expert at configuring AI agent swarms for codebase analysis.

Given this codebase profile, generate an AGENTS.md file with the following sections:

1. **Architecture Summary** — A concise overview of the repo structure, primary languages, and key components.

2. **Suggested Workflows** — Recommend direct commands for useful first passes:
   - \`swarm star <n> cxx\` — what multi-agent analysis would be worth launching
   - \`swarm wt <n> cxx\` — what parallel implementation work would benefit from worktree isolation

3. **Swarm Topology Guide** — Recommend the best swarm topology for common tasks:
   - \`swarm star <n> cxx\` — when and with how many agents
   - \`swarm wt <n> cxx\` — when worktree isolation helps
   - \`swarm pipe <n> cxx [--gated]\` — when pipeline stages make sense, and when to add human approval gates
   - \`swarm pair cxx\` — when pair review is best
   - \`swarm tournament <n> cxx \"<task>\" --rounds <r> --eval \"<criteria>\"\` — when to use competitive multi-agent tournaments (e.g. multiple approaches to the same problem, choosing the best implementation). Suggest specific tasks and evaluation criteria relevant to this codebase.

   The last argument selects the agent harness. Available: \`cxx\` (Claude Code YOLO), \`cdxx\` (Codex full-auto), \`pi\` (Pi minimal harness, no permission popups). Mix harnesses across topologies when their strengths fit (e.g. Pi for quick edits, Claude for deep reasoning).

4. **Quick Start** — 3-5 commands to run first after cloning this repo.

Output raw markdown only. No code fences around the whole document.

CODEBASE PROFILE:
$profile" 2>/dev/null)

  if [[ -z "$result" ]]; then
    echo "init: claude returned empty response" >&2
    return 1
  fi

  echo "$result" > "$output_path"
}

# ------------------------------------------------------------------------------
# Main command
# ------------------------------------------------------------------------------

anu_init() {
  git rev-parse --is-inside-work-tree &>/dev/null || {
    echo "init: not a git repo" >&2
    return 1
  }

  local git_root
  git_root=$(git rev-parse --show-toplevel 2>/dev/null)
  local force=0

  if [[ "${1:-}" == "--force" ]]; then
    force=1
  fi

  if [[ -f "$git_root/AGENTS.md" && "$force" -eq 0 ]]; then
    echo "init: AGENTS.md already exists. Use --force to regenerate."
    return 0
  fi

  mkdir -p "$_init_state_dir"

  _voice_say "Initializing project analysis"
  _voice_sound start

  # Step 1: Profile the repo
  local profile_path="$_init_state_dir/profile.md"

  echo -e "\033[36minit:\033[0m profiling repository..."
  _init_profile_repo "$profile_path" || {
    echo "init: failed to profile repo" >&2
    _voice_sound error
    return 1
  }

  _voice_say "Profile complete, generating recommendations"

  # Step 2: Generate AGENTS.md via Claude
  echo -e "\033[36minit:\033[0m generating AGENTS.md..."
  local agents_md="$git_root/AGENTS.md"

  _init_generate_agents_md "$profile_path" "$agents_md" || {
    echo "init: failed to generate AGENTS.md" >&2
    _voice_sound error
    return 1
  }

  _voice_say "AGENTS.md created"
  _voice_sound done

  echo -e "\033[36minit:\033[0m wrote $agents_md"
  echo -e "\033[36minit:\033[0m done — review AGENTS.md for swarm recommendations"
}
