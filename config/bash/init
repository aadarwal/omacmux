if command -v mise &> /dev/null; then
  eval "$(mise activate bash)"
fi

if command -v starship &> /dev/null; then
  eval "$(starship init bash)"
fi

if command -v zoxide &> /dev/null; then
  eval "$(zoxide init bash)"
fi

if command -v fzf &> /dev/null; then
  eval "$(fzf --bash)"
fi

# Auto-show device picker on fresh terminal windows
# Skips: inside tmux (use Prefix+m there), subshells
# Press Escape to dismiss and get a normal shell prompt
if [[ -z "$TMUX" && -z "$MESH_PICKER_SHOWN" ]]; then
  export MESH_PICKER_SHOWN=1
  mesh 2>/dev/null
fi
