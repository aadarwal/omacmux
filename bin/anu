#!/usr/bin/env bash
set -euo pipefail

# --- Resolve anu root (works from symlink or direct invocation) ---
_resolve_root() {
  local bin="$0"
  # Follow symlinks (macOS readlink -f equivalent)
  while [[ -L "$bin" ]]; do
    local dir; dir="$(cd "$(dirname "$bin")" && pwd)"
    bin="$(readlink "$bin")"
    [[ "$bin" != /* ]] && bin="$dir/$bin"
  done
  cd "$(dirname "$bin")/.." && pwd
}

ANU_ROOT="$(_resolve_root)"
ANU_LINK_PATH="$HOME/.local/share/anu"
ANU_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/anu"
MANIFEST="$ANU_STATE_DIR/manifest"
LEGACY_MANIFEST="$ANU_LINK_PATH/manifest"
BREW_BASH="/opt/homebrew/bin/bash"

source "$ANU_ROOT/links.sh"

# --- Colors ---
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
CYAN='\033[0;36m'; DIM='\033[2m'; BOLD='\033[1m'; NC='\033[0m'

# --- Helpers ---

_info()  { printf "${CYAN}==> %s${NC}\n" "$*"; }
_ok()    { printf "    ${GREEN}%s${NC} %s\n" "$1" "$2"; }
_warn()  { printf "    ${YELLOW}%s${NC} %s\n" "$1" "$2"; }
_err()   { printf "    ${RED}%s${NC} %s\n" "$1" "$2"; }
_dim()   { printf "    ${DIM}%s${NC}\n" "$*"; }

_file_info() {
  local path="$1"
  if [[ -d "$path" ]]; then
    local count; count=$(find "$path" -type f 2>/dev/null | wc -l | tr -d ' ')
    echo "directory, ${count} files"
  elif [[ -f "$path" ]]; then
    local lines; lines=$(wc -l < "$path" | tr -d ' ')
    local mod; mod=$(stat -f "%Sm" -t "%Y-%m-%d" "$path" 2>/dev/null || echo "unknown")
    echo "${lines} lines, modified ${mod}"
  else
    echo "unknown"
  fi
}

_backup_path() {
  echo "${1}.anu-bak.$(date +%Y%m%d_%H%M%S)"
}

_manifest_init() {
  mkdir -p "$ANU_STATE_DIR"
  if [[ ! -f "$MANIFEST" && -f "$LEGACY_MANIFEST" && "$LEGACY_MANIFEST" != "$MANIFEST" ]]; then
    cp "$LEGACY_MANIFEST" "$MANIFEST"
  fi
  if [[ ! -f "$MANIFEST" ]]; then
    printf "# anu link manifest — do not edit manually\n" > "$MANIFEST"
    printf "# format: strategy\\tsource\\ttarget\\tbackup_path\\n" >> "$MANIFEST"
  fi
}

_manifest_add() {
  local strategy="$1" source="$2" target="$3" backup="${4:-}"
  _manifest_init
  local tmp; tmp="$(mktemp)"
  awk -v target="$target" 'BEGIN { FS = OFS = "\t" } /^#/ || NF == 0 || $3 != target { print }' "$MANIFEST" > "$tmp"
  mv "$tmp" "$MANIFEST"
  printf "%s\t%s\t%s\t%s\n" "$strategy" "$source" "$target" "$backup" >> "$MANIFEST"
}

_manifest_entries() {
  [[ -f "$MANIFEST" ]] || return 0
  awk 'NF && $0 !~ /^#/' "$MANIFEST" || true
}

_is_anu_sourced() {
  local rel_source="$1" file="$2"
  [[ -f "$file" ]] || return 1
  case "$rel_source" in
    shell/bashrc)
      grep -Eq '# >>> anu shell/bashrc|source "\$ANU_PATH/shell/bashrc"|source .*/anu/shell/bashrc' "$file" 2>/dev/null
      ;;
    shell/bash_profile)
      grep -Eq '# >>> anu shell/bash_profile|^\[\[ -f ~/.bashrc \]\] && \. ~/.bashrc$|source ~/.bashrc|\. ~/.bashrc' "$file" 2>/dev/null
      ;;
    *)
      grep -Fq "# >>> anu $rel_source" "$file" 2>/dev/null || \
        grep -Fq "source \"$ANU_LINK_PATH/$rel_source\"" "$file" 2>/dev/null
      ;;
  esac
}

_ensure_repo_link() {
  mkdir -p "$(dirname "$ANU_LINK_PATH")"

  if [[ -L "$ANU_LINK_PATH" ]]; then
    rm "$ANU_LINK_PATH"
    ln -s "$ANU_ROOT" "$ANU_LINK_PATH"
    return 0
  fi

  if [[ -e "$ANU_LINK_PATH" ]]; then
    if [[ "$ANU_LINK_PATH" -ef "$ANU_ROOT" ]]; then
      return 0
    fi
    local bak; bak="$(_backup_path "$ANU_LINK_PATH")"
    mv "$ANU_LINK_PATH" "$bak"
    _dim "backed up existing ~/.local/share/anu to $(basename "$bak")"
  fi

  ln -s "$ANU_ROOT" "$ANU_LINK_PATH"
  _ok "linked" "~/.local/share/anu -> $ANU_ROOT"
}

_remove_merge_lines() {
  local rel_source="$1" target="$2"
  local tmp; tmp="$(mktemp)"
  local status=0
  awk '
    /^# >>> anu / { skip = 1; changed = 1; next }
    /^# <<< anu / { skip = 0; next }
    skip { next }
    { print }
    END { if (changed) exit 10 }
  ' "$target" > "$tmp" || status=$?

  if [[ $status -eq 10 ]]; then
    mv "$tmp" "$target"
    return 0
  elif [[ $status -ne 0 ]]; then
    rm -f "$tmp"
    return 1
  fi
  rm -f "$tmp"

  case "$rel_source" in
    shell/bashrc)
      tmp="$(mktemp)"
      grep -v -E '^# anu$|^export ANU_PATH="\$\{ANU_PATH:-\$HOME/\.local/share/anu\}"$|^\[\[ \$- == \*i\* \]\] && source "\$ANU_PATH/shell/bashrc"$' "$target" > "$tmp" 2>/dev/null || true
      if ! diff -q "$target" "$tmp" &>/dev/null; then
        mv "$tmp" "$target"
        return 0
      fi
      rm -f "$tmp"
      ;;
    *)
      return 1
      ;;
  esac

  return 1
}

# --- INIT ---

_cmd_init() {
  local mode="interactive"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --replace-all) mode="replace" ;;
      --merge-all)   mode="merge" ;;
      --skip-existing) mode="skip" ;;
      -h|--help) _init_help; return 0 ;;
      *) echo "Unknown option: $1"; _init_help; return 1 ;;
    esac
    shift
  done

  _info "anu init"
  echo ""
  _manifest_init

  # Install Homebrew deps if brew is available
  if command -v brew &>/dev/null; then
    _info "Checking Homebrew dependencies..."
    HOMEBREW_NO_AUTO_UPDATE=1 brew bundle check --file="$ANU_ROOT/Brewfile" &>/dev/null \
      && _ok "ok" "all dependencies installed" \
      || {
        _warn "installing" "missing dependencies..."
        HOMEBREW_NO_AUTO_UPDATE=1 brew bundle --file="$ANU_ROOT/Brewfile"
      }
    echo ""
  fi

  # Add Homebrew bash to /etc/shells
  if [[ -f "$BREW_BASH" ]] && ! grep -q "$BREW_BASH" /etc/shells 2>/dev/null; then
    _warn "sudo" "Adding Homebrew bash to /etc/shells..."
    echo "$BREW_BASH" | sudo tee -a /etc/shells > /dev/null
  fi

  _ensure_repo_link

  _info "Linking config files..."
  echo ""

  local linked=0 skipped=0 merged=0

  for entry in "${ANU_LINKS[@]}"; do
    anu_parse_link "$entry"
    local src="$ANU_ROOT/$_source"
    local dest="$_dest"
    local strategy="$_strategy"

    # If source doesn't exist, skip
    if [[ ! -e "$src" ]]; then
      _warn "skip" "$dest — source missing ($src)"
      continue
    fi

    # Already correctly linked
    if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
      _ok "ok" "$dest"
      _manifest_add "$strategy" "$src" "$dest" ""
      linked=$((linked + 1))
      continue
    fi

    # Already merged
    if [[ "$strategy" == "merge" ]] && _is_anu_sourced "$_source" "$dest"; then
      _ok "ok" "$dest (merged)"
      _manifest_add "merge" "$src" "$dest" ""
      merged=$((merged + 1))
      continue
    fi

    # No existing file — just link
    if [[ ! -e "$dest" && ! -L "$dest" ]]; then
      mkdir -p "$(dirname "$dest")"
      if [[ "$strategy" == "merge" ]]; then
        # Create a minimal file that sources anu
        _write_merge_stub "$_source" "$dest"
        _ok "created" "$dest (merged)"
        _manifest_add "merge" "$src" "$dest" ""
        merged=$((merged + 1))
      else
        ln -s "$src" "$dest"
        _ok "linked" "$dest"
        _manifest_add "$strategy" "$src" "$dest" ""
        linked=$((linked + 1))
      fi
      continue
    fi

    # --- Conflict: file exists ---

    local action=""
    case "$mode" in
      replace) action="r" ;;
      merge)   [[ "$strategy" == "merge" ]] && action="m" || action="r" ;;
      skip)    action="s" ;;
      interactive) action="$(_prompt_conflict "$strategy" "$src" "$dest")" ;;
    esac

    case "$action" in
      r)
        local bak; bak="$(_backup_path "$dest")"
        if [[ -L "$dest" ]]; then
          rm "$dest"
        else
          mv "$dest" "$bak"
          _dim "backed up to $(basename "$bak")"
        fi
        mkdir -p "$(dirname "$dest")"
        ln -s "$src" "$dest"
        _ok "replaced" "$dest"
        _manifest_add "replace" "$src" "$dest" "$bak"
        linked=$((linked + 1))
        ;;
      m)
        if [[ "$strategy" == "merge" ]]; then
          _append_source_line "$_source" "$dest"
          _ok "merged" "$dest"
          _manifest_add "merge" "$src" "$dest" ""
          merged=$((merged + 1))
        else
          _warn "skip" "$dest — merge not supported for this file"
          skipped=$((skipped + 1))
        fi
        ;;
      s)
        _warn "skip" "$dest"
        skipped=$((skipped + 1))
        ;;
    esac
  done

  # Copy mesh templates
  for f in hosts users; do
    if [[ ! -f "$ANU_ROOT/mesh/${f}.json" && -f "$ANU_ROOT/mesh/${f}.example.json" ]]; then
      cp "$ANU_ROOT/mesh/${f}.example.json" "$ANU_ROOT/mesh/${f}.json"
      _ok "created" "mesh/${f}.json from template"
    fi
  done

  echo ""
  _info "Done — ${linked} linked, ${merged} merged, ${skipped} skipped"

  # Git identity prompt (only if not already configured)
  local git_cfg="$ANU_ROOT/config/git/config"
  if [[ -f "$git_cfg" ]] && ! grep -q '^\[user\]' "$git_cfg" 2>/dev/null; then
    echo ""
    _info "Git identity"
    read -rp "    Your name for git commits: " git_name
    read -rp "    Your email for git commits: " git_email
    if [[ -n "${git_name:-}" && -n "${git_email:-}" ]]; then
      printf "\n[user]\n\temail = %s\n\tname = %s\n" "$git_email" "$git_name" >> "$git_cfg"
      _ok "saved" "git identity"
    else
      _dim "Skipped — set later with 'git config --global'"
    fi
  fi

  # Offer to switch shell
  if [[ -f "$BREW_BASH" && "${SHELL:-}" != "$BREW_BASH" ]]; then
    echo ""
    read -rp "$(printf "${CYAN}==> Set Homebrew bash as default shell? [y/N]${NC} ")" -n 1 reply
    echo
    if [[ "${reply:-}" =~ ^[Yy]$ ]]; then
      chsh -s "$BREW_BASH"
      _ok "done" "default shell changed to $BREW_BASH"
    else
      _dim "Keeping $SHELL. Run 'chsh -s $BREW_BASH' later if needed."
    fi
  fi

  echo ""
  echo "    Open a new terminal, then run:  t"
  echo ""
}

_prompt_conflict() {
  local strategy="$1" src="$2" dest="$3"
  local info; info="$(_file_info "$dest")"

  printf "\n  ${BOLD}%s${NC}\n" "$dest"
  printf "    ${YELLOW}conflict${NC} — file exists (${DIM}%s${NC})\n" "$info"

  while true; do
    if [[ "$strategy" == "merge" ]]; then
      printf "    [${GREEN}m${NC}] Merge — append 'source anu' to your file\n"
    fi
    printf "    [${RED}r${NC}] Replace — backup yours, symlink ours\n"
    printf "    [${CYAN}v${NC}] View diff\n"
    printf "    [${DIM}s${NC}] Skip\n"

    local default="r"
    [[ "$strategy" == "merge" ]] && default="m"

    read -rp "    Choice [$default]: " -n 1 choice
    echo
    choice="${choice:-$default}"

    case "$choice" in
      m) [[ "$strategy" == "merge" ]] && { echo "m"; return; } ;;
      r) echo "r"; return ;;
      s) echo "s"; return ;;
      v)
        echo ""
        if command -v diff &>/dev/null; then
          diff --color=auto -u "$dest" "$src" 2>/dev/null | head -60 || true
        else
          diff -u "$dest" "$src" 2>/dev/null | head -60 || true
        fi
        echo ""
        ;;
      *) _dim "Invalid choice. Try again." ;;
    esac
  done
}

_write_merge_stub() {
  local rel_source="$1" dest="$2"
  mkdir -p "$(dirname "$dest")"
  case "$rel_source" in
    shell/bashrc)
      cat > "$dest" <<'STUB'
# >>> anu shell/bashrc
export ANU_PATH="${ANU_PATH:-$HOME/.local/share/anu}"
[[ $- == *i* ]] && source "$ANU_PATH/shell/bashrc"
# <<< anu shell/bashrc
STUB
      ;;
    shell/bash_profile)
      cat > "$dest" <<'STUB'
# >>> anu shell/bash_profile
[[ -f ~/.bashrc ]] && . ~/.bashrc
# <<< anu shell/bash_profile
STUB
      ;;
    *)
      # Generic: just source it
      printf '# >>> anu %s\nsource "%s/%s"\n# <<< anu %s\n' "$rel_source" '$HOME/.local/share/anu' "$rel_source" "$rel_source" > "$dest"
      ;;
  esac
}

_append_source_line() {
  local rel_source="$1" dest="$2"
  _is_anu_sourced "$rel_source" "$dest" && return 0
  case "$rel_source" in
    shell/bashrc)
      printf '\n# >>> anu shell/bashrc\nexport ANU_PATH="${ANU_PATH:-$HOME/.local/share/anu}"\n[[ $- == *i* ]] && source "$ANU_PATH/shell/bashrc"\n# <<< anu shell/bashrc\n' >> "$dest"
      ;;
    shell/bash_profile)
      if ! grep -q '\. ~/.bashrc\|source ~/.bashrc' "$dest" 2>/dev/null; then
        printf '\n# >>> anu shell/bash_profile\n[[ -f ~/.bashrc ]] && . ~/.bashrc\n# <<< anu shell/bash_profile\n' >> "$dest"
      fi
      ;;
    *)
      printf '\n# >>> anu %s\nsource "%s/%s"\n# <<< anu %s\n' "$rel_source" '$HOME/.local/share/anu' "$rel_source" "$rel_source" >> "$dest"
      ;;
  esac
}

_init_help() {
  cat <<EOF
Usage: anu init [OPTIONS]

Set up anu config files with interactive conflict resolution.

Options:
  --replace-all     Replace all existing files (backup originals)
  --merge-all       Merge where possible, replace the rest
  --skip-existing   Skip any file that already exists
  -h, --help        Show this help

When run without options, prompts for each conflicting file.
EOF
}

# --- UNLINK ---

_cmd_unlink() {
  _info "anu unlink"
  echo ""

  if [[ ! -f "$MANIFEST" ]]; then
    _err "error" "No manifest found — nothing to unlink."
    return 1
  fi

  local count=0

  while IFS=$'\t' read -r strategy source target backup; do
    [[ -z "$target" ]] && continue

    case "$strategy" in
      replace|additive)
        if [[ -L "$target" ]]; then
          rm "$target"
          if [[ -n "$backup" && -e "$backup" ]]; then
            mv "$backup" "$target"
            _ok "restored" "$target"
          else
            _ok "removed" "$target"
          fi
          count=$((count + 1))
        else
          _warn "skip" "$target — not a symlink"
        fi
        ;;
      merge)
        if [[ -f "$target" ]]; then
          local rel_source="${source#$ANU_ROOT/}"
          if _remove_merge_lines "$rel_source" "$target"; then
            _ok "cleaned" "$target — removed anu source lines"
            count=$((count + 1))
          else
            _warn "skip" "$target — no anu lines found"
          fi
        fi
        ;;
    esac
  done < <(_manifest_entries)

  # Remove source symlink
  if [[ -L "$ANU_LINK_PATH" ]]; then
    rm "$ANU_LINK_PATH"
    _ok "removed" "~/.local/share/anu symlink"
  fi

  # Clear manifest
  rm -f "$MANIFEST"
  rmdir "$ANU_STATE_DIR" 2>/dev/null || true

  echo ""
  _info "Done — $count files unlinked/restored"
  echo ""
  _dim "Homebrew packages were NOT removed."
  _dim "Run 'brew bundle cleanup --file=$ANU_ROOT/Brewfile --force' to remove them."
}

# --- STATUS ---

_cmd_status() {
  _info "anu status"
  echo ""

  printf "    %-10s  %-50s  %s\n" "STATE" "TARGET" "STRATEGY"
  printf "    %-10s  %-50s  %s\n" "-----" "------" "--------"

  for entry in "${ANU_LINKS[@]}"; do
    anu_parse_link "$entry"
    local src="$ANU_ROOT/$_source"
    local dest="$_dest"
    local short_dest="${dest/#$HOME/~}"
    local state=""

    if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
      state="${GREEN}linked${NC}"
    elif [[ "$_strategy" == "merge" ]] && _is_anu_sourced "$_source" "$dest"; then
      state="${GREEN}merged${NC}"
    elif [[ -e "$dest" ]]; then
      state="${YELLOW}conflict${NC}"
    elif [[ -L "$dest" ]]; then
      state="${RED}broken${NC}"
    else
      state="${DIM}missing${NC}"
    fi

    printf "    ${state}%-4s  %-50s  ${DIM}%s${NC}\n" "" "$short_dest" "$_strategy"
  done
  echo ""
}

# --- DOCTOR ---

_cmd_doctor() {
  _info "anu doctor"
  echo ""
  local issues=0

  # Check Homebrew
  if command -v brew &>/dev/null; then
    _ok "ok" "Homebrew installed"
    if HOMEBREW_NO_AUTO_UPDATE=1 brew bundle check --file="$ANU_ROOT/Brewfile" &>/dev/null; then
      _ok "ok" "all Brewfile dependencies installed"
    else
      _err "missing" "some Brewfile dependencies — run 'anu init' or 'brew bundle'"
      issues=$((issues + 1))
    fi
  else
    _err "missing" "Homebrew not installed"
    issues=$((issues + 1))
  fi

  # Check bash version
  local bash_ver; bash_ver="$("${BREW_BASH:-bash}" --version 2>/dev/null | head -1 || echo "")"
  if [[ "$bash_ver" == *"version 5"* || "$bash_ver" == *"version 4"* ]]; then
    _ok "ok" "bash 4+ ($(basename "${BREW_BASH:-bash}"))"
  else
    _warn "warn" "bash is < 4.0 — some features may not work"
    issues=$((issues + 1))
  fi

  # Check shell
  if [[ "${SHELL:-}" == "$BREW_BASH" ]]; then
    _ok "ok" "default shell is Homebrew bash"
  else
    _warn "info" "default shell is $SHELL (anu prefers $BREW_BASH)"
  fi

  # Check symlinks
  local broken=0
  for entry in "${ANU_LINKS[@]}"; do
    anu_parse_link "$entry"
    local dest="$_dest"
    if [[ -L "$dest" ]] && [[ ! -e "$dest" ]]; then
      _err "broken" "$dest -> $(readlink "$dest")"
      broken=$((broken + 1))
    fi
  done
  if [[ $broken -eq 0 ]]; then
    _ok "ok" "no broken symlinks"
  else
    issues=$((issues + broken))
  fi

  # Check source link
  if [[ -L "$ANU_LINK_PATH" && "$(readlink "$ANU_LINK_PATH")" == "$ANU_ROOT" ]]; then
    _ok "ok" "source link (~/.local/share/anu)"
  elif [[ -L "$ANU_LINK_PATH" ]]; then
    _warn "warn" "~/.local/share/anu points to $(readlink "$ANU_LINK_PATH")"
    issues=$((issues + 1))
  elif [[ -e "$ANU_LINK_PATH" ]]; then
    _warn "warn" "~/.local/share/anu exists but is not a symlink"
    issues=$((issues + 1))
  else
    _warn "missing" "source link — run 'anu init'"
    issues=$((issues + 1))
  fi

  # Check manifest
  if [[ -f "$MANIFEST" ]]; then
    local link_count; link_count=$(awk 'NF && $0 !~ /^#/ { count++ } END { print count + 0 }' "$MANIFEST" 2>/dev/null || echo "0")
    _ok "ok" "manifest ($link_count entries at $MANIFEST)"
  else
    _warn "missing" "manifest — run 'anu init'"
    issues=$((issues + 1))
  fi

  echo ""
  if [[ $issues -eq 0 ]]; then
    _info "All checks passed"
  else
    _info "$issues issue(s) found"
  fi
}

# --- UPGRADE ---

_cmd_upgrade() {
  _info "anu upgrade"
  echo ""

  # Pull latest
  _info "Pulling latest changes..."
  local before; before=$(git -C "$ANU_ROOT" rev-parse HEAD 2>/dev/null || echo "")
  local pull_ok=1
  git -C "$ANU_ROOT" pull --rebase 2>/dev/null && pull_ok=0 || {
    _warn "skip" "git pull failed (not a git repo or no remote)"
  }
  local after; after=$(git -C "$ANU_ROOT" rev-parse HEAD 2>/dev/null || echo "")

  if [[ $pull_ok -eq 0 && -n "$before" && "$before" != "$after" ]]; then
    _ok "updated" "${before:0:7} -> ${after:0:7}"
    git -C "$ANU_ROOT" log --oneline "${before}..${after}" | sed 's/^/    /'
  elif [[ $pull_ok -eq 0 ]]; then
    _ok "ok" "already up to date"
  fi
  echo ""

  # Sync deps
  if command -v brew &>/dev/null; then
    _info "Syncing Homebrew dependencies..."
    HOMEBREW_NO_AUTO_UPDATE=1 brew bundle --file="$ANU_ROOT/Brewfile" 2>/dev/null
    _ok "ok" "dependencies synced"
    echo ""
  fi

  # Re-run init in non-interactive mode for new links
  _info "Syncing config links..."
  source "$ANU_ROOT/links.sh"
  _manifest_init
  _ensure_repo_link

  for entry in "${ANU_LINKS[@]}"; do
    anu_parse_link "$entry"
    local src="$ANU_ROOT/$_source"
    local dest="$_dest"

    [[ ! -e "$src" ]] && continue

    # Already correct
    if [[ -L "$dest" ]] && [[ "$(readlink "$dest")" == "$src" ]]; then
      _manifest_add "$_strategy" "$src" "$dest" ""
      continue
    fi
    if [[ "$_strategy" == "merge" ]] && _is_anu_sourced "$_source" "$dest"; then
      _manifest_add "merge" "$src" "$dest" ""
      continue
    fi

    # New link that didn't exist before — add it
    if [[ ! -e "$dest" && ! -L "$dest" ]]; then
      mkdir -p "$(dirname "$dest")"
      if [[ "$_strategy" == "merge" ]]; then
        _write_merge_stub "$_source" "$dest"
        _ok "new" "$dest (merged)"
      else
        ln -s "$src" "$dest"
        _ok "new" "$dest"
      fi
      _manifest_add "$_strategy" "$src" "$dest" ""
      continue
    fi

    # Existing conflict — don't touch during upgrade, just report
    if [[ -e "$dest" ]]; then
      _warn "conflict" "$dest — run 'anu init' to resolve"
    fi
  done

  echo ""
  _info "Upgrade complete"
}

# --- HELP ---

_cmd_help() {
  cat <<EOF
${BOLD}anu${NC} — agent-first IDE for macOS

${BOLD}Usage:${NC}
  anu <command> [options]

${BOLD}Commands:${NC}
  init        Set up config files (interactive conflict resolution)
  unlink      Remove all anu configs, restore backups
  status      Show current state of all config links
  upgrade     Pull latest + sync dependencies + update links
  doctor      Check installation health
  help        Show this help

${BOLD}Init options:${NC}
  --replace-all     Non-interactive: replace all existing files
  --merge-all       Non-interactive: merge shell files, replace the rest
  --skip-existing   Non-interactive: skip any file that already exists

${BOLD}Install via Homebrew:${NC}
  brew install aadarwal/tap/anu
  anu init

${BOLD}Install via git clone:${NC}
  git clone https://github.com/aadarwal/anu.git ~/anu
  ~/anu/bin/anu init
EOF
}

# --- Main dispatch ---

case "${1:-help}" in
  init)    shift; _cmd_init "$@" ;;
  unlink)  _cmd_unlink ;;
  status)  _cmd_status ;;
  upgrade) _cmd_upgrade ;;
  doctor)  _cmd_doctor ;;
  help|-h|--help) _cmd_help ;;
  *)
    printf "${RED}Unknown command: %s${NC}\n\n" "$1"
    _cmd_help
    exit 1
    ;;
esac
